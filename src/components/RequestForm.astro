---
// Multi-step project enquiry. Submits to Web3Forms (same backend as before).
---
<div class="rf" id="request-form">
  <form id="rf-form" novalidate>
    <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? ''} />
    <input type="hidden" name="subject" value="New project enquiry — ppc.space" />
    <input type="hidden" name="from_name" value="PPC Website" />
    <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />
    <input type="hidden" name="quantity" id="rf-quantity" />
    <input type="hidden" name="timeline" id="rf-timeline" />

    <p class="rf__intro">A few quick questions. We reply within one business day.</p>
    <p class="rf__progress" aria-live="polite">Step <span data-current>1</span> of <span data-total>4</span></p>

    <div class="rf__step" data-step="1">
      <label class="rf__q" for="rf-project">What are you working on?</label>
      <input class="rf__input" type="text" name="project" id="rf-project" autocomplete="off" placeholder="A drop, staff merch, an event…" />
      <button type="button" class="rf__next" data-next>Next →</button>
    </div>

    <div class="rf__step" data-step="2" hidden>
      <p class="rf__q">How many pieces?</p>
      <div class="rf__choices">
        <button type="button" class="rf__choice" data-field="quantity" data-value="1–20">1–20</button>
        <button type="button" class="rf__choice" data-field="quantity" data-value="20–100">20–100</button>
        <button type="button" class="rf__choice" data-field="quantity" data-value="100–500">100–500</button>
        <button type="button" class="rf__choice" data-field="quantity" data-value="500+">500+</button>
      </div>
    </div>

    <div class="rf__step" data-step="3" hidden>
      <p class="rf__q">When do you need it?</p>
      <div class="rf__choices">
        <button type="button" class="rf__choice" data-field="timeline" data-value="ASAP">ASAP</button>
        <button type="button" class="rf__choice" data-field="timeline" data-value="This month">This month</button>
        <button type="button" class="rf__choice" data-field="timeline" data-value="Next month">Next month</button>
        <button type="button" class="rf__choice" data-field="timeline" data-value="Just exploring">Just exploring</button>
      </div>
    </div>

    <div class="rf__step" data-step="4" hidden>
      <label class="rf__q" for="rf-email">Your email</label>
      <input class="rf__input" type="email" name="email" id="rf-email" autocomplete="email" placeholder="you@example.com" />
      <button type="submit" class="rf__send" id="rf-submit">Send →</button>
      <p class="rf__error" id="rf-error" hidden>Something went wrong. Try again or email us directly.</p>
    </div>

    <button type="button" class="rf__back" data-back hidden>← Back</button>
  </form>

  <div class="rf__success" id="rf-success" hidden>
    <p class="rf__success-text">Got it. We'll reply within 24 hours.</p>
  </div>
</div>

<style>
  .rf { max-width: 24rem; }

  .rf__intro {
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-mute);
    margin: 0 0 1rem;
    max-width: 24rem;
  }
  .rf__progress {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-faint);
    margin: 0 0 1.5rem;
  }

  .rf__q {
    display: block;
    font-size: 1.125rem;
    line-height: 1.3;
    margin: 0 0 1.25rem;
    color: var(--color-text);
  }

  .rf__input {
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--color-text);
    background: transparent;
    padding: 0.5rem 0;
    font-size: 1rem;
    color: var(--color-text);
  }
  .rf__input::placeholder { color: var(--color-faint); }
  .rf__input:focus { outline: none; border-color: var(--color-accent); }

  .rf__choices { display: flex; flex-direction: column; gap: 0.6rem; }
  .rf__choice {
    text-align: left;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-rule-strong);
    background: #fff;
    font-size: 0.9375rem;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }
  .rf__choice:hover,
  .rf__choice.is-selected {
    background: var(--color-text);
    color: #fff;
    border-color: var(--color-text);
  }

  .rf__next, .rf__send {
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.6rem 1.1rem;
    background: var(--color-text);
    color: #fff;
    border: 1px solid var(--color-text);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .rf__next:hover, .rf__send:hover { background: #fff; color: var(--color-text); }

  .rf__back {
    margin-top: 1.75rem;
    border: 0;
    background: transparent;
    font-size: 0.8125rem;
    color: var(--color-mute);
    cursor: pointer;
    padding: 0;
  }
  .rf__back:hover { color: var(--color-text); }

  .rf__error { margin-top: 0.9rem; font-size: 0.8125rem; color: var(--color-accent); }
  .rf__success-text { font-size: 1.125rem; color: var(--color-text); }
</style>

<script>
  function initRequestForm() {
    const root = document.getElementById('request-form');
    if (!root) return;
    const form = root.querySelector<HTMLFormElement>('#rf-form');
    const steps = Array.from(root.querySelectorAll<HTMLElement>('.rf__step'));
    const currentLabel = root.querySelector<HTMLElement>('[data-current]');
    const totalLabel = root.querySelector<HTMLElement>('[data-total]');
    const backBtn = root.querySelector<HTMLButtonElement>('[data-back]');
    const submitBtn = root.querySelector<HTMLButtonElement>('#rf-submit');
    const errorEl = root.querySelector<HTMLElement>('#rf-error');
    const successEl = root.querySelector<HTMLElement>('#rf-success');
    const projectInput = root.querySelector<HTMLInputElement>('#rf-project');
    const emailInput = root.querySelector<HTMLInputElement>('#rf-email');
    if (!form) return;

    const total = steps.length;
    if (totalLabel) totalLabel.textContent = String(total); // derived, not hardcoded
    let step = 1;

    function show(n: number) {
      step = Math.max(1, Math.min(total, n));
      steps.forEach((el) => {
        el.hidden = Number(el.dataset.step) !== step;
      });
      if (currentLabel) currentLabel.textContent = String(step);
      if (backBtn) backBtn.hidden = step === 1;
      const active = steps[step - 1];
      active.querySelector<HTMLElement>('input, button')?.focus();
    }

    // Text step: Next
    root.querySelector('[data-next]')?.addEventListener('click', () => {
      if (!projectInput?.value.trim()) { projectInput?.focus(); return; }
      show(2);
    });

    // Choice steps: select + auto-advance
    root.querySelectorAll<HTMLButtonElement>('.rf__choice').forEach((btn) => {
      btn.addEventListener('click', () => {
        const field = btn.dataset.field!;
        const value = btn.dataset.value!;
        const hidden = root.querySelector<HTMLInputElement>(`#rf-${field}`);
        if (hidden) hidden.value = value;
        // visual selection within this step
        btn.parentElement?.querySelectorAll('.rf__choice').forEach((b) => b.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        window.setTimeout(() => show(step + 1), 180);
      });
    });

    backBtn?.addEventListener('click', () => show(step - 1));

    // Enter advances on text steps
    projectInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); if (projectInput.value.trim()) show(2); }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!emailInput?.value.trim() || !emailInput.checkValidity()) { emailInput?.focus(); return; }
      if (submitBtn) { submitBtn.textContent = 'Sending…'; submitBtn.disabled = true; }
      errorEl?.setAttribute('hidden', '');

      const data = Object.fromEntries(new FormData(form));
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (json.success) {
          form.hidden = true;
          successEl?.removeAttribute('hidden');
        } else {
          throw new Error(json.message ?? 'failed');
        }
      } catch {
        errorEl?.removeAttribute('hidden');
        if (submitBtn) { submitBtn.textContent = 'Send →'; submitBtn.disabled = false; }
      }
    });

    // Reset to step 1 each time the contact overlay opens.
    document.addEventListener('ppc:open-contact', () => {
      if (form.hidden) { form.hidden = false; successEl?.setAttribute('hidden', ''); }
      show(1);
    });

    show(1);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRequestForm);
  } else {
    initRequestForm();
  }
</script>
