---
import TeeCell from './TeeCell.astro';
import { cases } from '../data/cases';

// Two streams show different orderings so the columns never mirror each other.
// The contact tee ("Your project goes here") is woven into each stream once.
const half = Math.ceil(cases.length / 2);
const leftSeq = cases;
const rightSeq = [...cases.slice(half), ...cases.slice(0, half)];

// Three copies per column → seamless modulo wrap in both directions.
const copies = [0, 1, 2];
---
<div class="gallery" id="gallery">
  <div class="stream stream--left" data-stream="left">
    <div class="stream__track" data-track>
      {copies.map((copy) => (
        <div class="stream__set" data-set aria-hidden={copy > 0 ? 'true' : 'false'}>
          {leftSeq.map((c) => <TeeCell item={c} />)}
          <TeeCell variant="contact" />
        </div>
      ))}
    </div>
  </div>

  <div class="stream stream--right" data-stream="right">
    <div class="stream__track" data-track>
      {copies.map((copy) => (
        <div class="stream__set" data-set aria-hidden={copy > 0 ? 'true' : 'false'}>
          {rightSeq.map((c) => <TeeCell item={c} />)}
          <TeeCell variant="contact" />
        </div>
      ))}
    </div>
  </div>

  <p class="gallery__hint" aria-hidden="true">Scroll</p>
</div>

<style>
  .gallery {
    position: fixed;
    inset: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: #fff;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(1.5rem, 6vw, 7rem);
    padding: 0 clamp(1rem, 5vw, 5rem);
    touch-action: none;
  }

  .stream { position: relative; overflow: visible; }

  .stream__track { will-change: transform; }

  .stream__set {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 4vh, 3rem);
    padding-block: clamp(1.25rem, 4vh, 3rem) 0;
  }

  .gallery__hint {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    transform: translateX(-50%);
    margin: 0;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-faint);
    pointer-events: none;
    animation: hint-fade 4s ease-in-out 1.5s forwards;
  }
  @keyframes hint-fade {
    to { opacity: 0; }
  }

  /* Reduced motion / no-JS: revert to a calm scrollable grid */
  .gallery.is-reduced {
    position: static;
    height: auto;
    min-height: 100vh;
    overflow: visible;
    padding-block: clamp(3rem, 10vh, 7rem);
    touch-action: auto;
  }
  .gallery.is-reduced .stream__set[aria-hidden='true'] { display: none; }
  .gallery.is-reduced .stream__track { transform: none !important; }
  .gallery.is-reduced .gallery__hint { display: none; }

  /* Before JS boots, avoid a flash of all three copies stacked */
  .gallery:not(.is-ready):not(.is-reduced) .stream__set:not(:first-child) {
    visibility: hidden;
  }
</style>

<script>
  type Stream = { track: HTMLElement; dir: number; cycle: number };

  function initGallery() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      gallery.classList.add('is-reduced');
      wireClicks(gallery);
      return;
    }

    const trackEls = Array.from(gallery.querySelectorAll<HTMLElement>('[data-track]'));
    const streams: Stream[] = trackEls.map((track, i) => ({
      track,
      dir: i === 0 ? -1 : 1, // left moves up, right moves down as offset grows
      cycle: 1,
    }));

    // Buttons in duplicate sets shouldn't be tab-stops.
    gallery.querySelectorAll<HTMLElement>('[data-set][aria-hidden="true"] button')
      .forEach((b) => b.setAttribute('tabindex', '-1'));

    const SPEED = 0.85;     // wheel sensitivity
    const TOUCH = 1.15;     // touch drag sensitivity
    const KEY_STEP = 320;   // keyboard nudge
    const EASE = 0.08;      // inertia toward target

    let target = 0;
    let current = 0;

    function measure() {
      for (const s of streams) {
        const firstSet = s.track.querySelector<HTMLElement>('[data-set]');
        s.cycle = firstSet ? firstSet.getBoundingClientRect().height : 1;
      }
    }
    measure();
    gallery.classList.add('is-ready');

    const overlayOpen = () => document.body.classList.contains('overlay-open');
    const wrap = (v: number, m: number) => ((v % m) + m) % m;

    function render() {
      current += (target - current) * EASE;
      for (const s of streams) {
        // Home each track on its middle copy, then drift by direction.
        const y = -s.cycle + s.dir * wrap(current, s.cycle);
        s.track.style.transform = `translate3d(0, ${y}px, 0)`;
      }
      requestAnimationFrame(render);
    }
    requestAnimationFrame(render);

    gallery.addEventListener(
      'wheel',
      (e: WheelEvent) => {
        if (overlayOpen()) return;
        e.preventDefault();
        target += e.deltaY * SPEED;
      },
      { passive: false }
    );

    let touchY = 0;
    gallery.addEventListener(
      'touchstart',
      (e: TouchEvent) => { touchY = e.touches[0].clientY; },
      { passive: true }
    );
    gallery.addEventListener(
      'touchmove',
      (e: TouchEvent) => {
        if (overlayOpen()) return;
        const y = e.touches[0].clientY;
        target += (touchY - y) * TOUCH;
        touchY = y;
        e.preventDefault();
      },
      { passive: false }
    );

    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (overlayOpen()) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') {
        target += KEY_STEP; e.preventDefault();
      } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        target -= KEY_STEP; e.preventDefault();
      }
    });

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(measure, 150);
    });

    wireClicks(gallery);
  }

  function wireClicks(gallery: HTMLElement) {
    gallery.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const contact = target.closest('[data-contact]');
      if (contact) {
        document.dispatchEvent(new CustomEvent('ppc:open-contact'));
        return;
      }
      const project = target.closest<HTMLElement>('[data-project]');
      if (project) {
        document.dispatchEvent(
          new CustomEvent('ppc:open-project', { detail: project.dataset.project })
        );
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
</script>
