---
import TeeCell from './TeeCell.astro';
import { cases } from '../data/cases';

// Each project is assigned to one desktop column (a = left, b = right) so the
// same item never shows in both columns at once. Both streams render the full
// list (tagged a/b) and CSS shows only the matching half per column on desktop;
// on mobile the single (left) column shows everything.
const col = (i: number): 'a' | 'b' => (i % 2 === 0 ? 'a' : 'b');

// Three copies per column → seamless modulo wrap in both directions.
const copies = [0, 1, 2];
---
<div class="gallery" id="gallery">
  <div class="stream stream--left" data-stream="left">
    <div class="stream__track" data-track>
      {copies.map((copy) => (
        <div class="stream__set" data-set aria-hidden={copy > 0 ? 'true' : 'false'}>
          {cases.map((c, i) => <TeeCell item={c} col={col(i)} />)}
          <TeeCell variant="contact" col="a" />
        </div>
      ))}
    </div>
  </div>

  <div class="stream stream--right" data-stream="right">
    <div class="stream__track" data-track>
      {copies.map((copy) => (
        <div class="stream__set" data-set aria-hidden={copy > 0 ? 'true' : 'false'}>
          {cases.map((c, i) => <TeeCell item={c} col={col(i)} />)}
          <TeeCell variant="contact" col="b" />
        </div>
      ))}
    </div>
  </div>

</div>

<style>
  .gallery {
    /* fills the space under the hero (parent .home is fixed full-height) */
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    background: #fff;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(1.5rem, 6vw, 7rem);
    padding: 0 clamp(1rem, 5vw, 5rem);
    touch-action: none;
  }

  /* Mobile: a single vertical carousel — the opposing columns read poorly
     on a narrow screen, and one stream is cheaper to animate. */
  @media (max-width: 640px) {
    .gallery {
      grid-template-columns: 1fr;
      column-gap: 0;
      padding: 0 1rem;
    }
    .stream--right { display: none; }
  }

  /* Desktop: split the projects across the two columns so the same item is
     never shown on both sides at once (left = set A, right = set B). */
  @media (min-width: 641px) {
    .stream--left :global([data-col='b']) { display: none; }
    .stream--right :global([data-col='a']) { display: none; }
  }

  .stream { position: relative; overflow: visible; }

  .stream__track {
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
    contain: layout paint;
  }

  .stream__set {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(1.25rem, 5vw, 3rem);
    padding-block: clamp(1.25rem, 5vw, 3rem) 0;
  }

  /* Reduced motion / no-JS: revert to a calm scrollable grid */
  .gallery.is-reduced {
    position: static;
    height: auto;
    min-height: 100vh;
    overflow: visible;
    padding-block: clamp(3rem, 10vh, 7rem);
    touch-action: auto;
  }
  .gallery.is-reduced .stream__set[aria-hidden='true'] { display: none; }
  .gallery.is-reduced .stream__track { transform: none !important; }

  /* Before JS boots, avoid a flash of all three copies stacked */
  .gallery:not(.is-ready):not(.is-reduced) .stream__set:not(:first-child) {
    visibility: hidden;
  }
</style>

<script>
  type Stream = { track: HTMLElement; dir: number; cycle: number; visible: boolean };

  function initGallery() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      gallery.classList.add('is-reduced');
      wireClicks(gallery);
      return;
    }

    const trackEls = Array.from(gallery.querySelectorAll<HTMLElement>('[data-track]'));
    const streams: Stream[] = trackEls.map((track, i) => ({
      track,
      dir: i === 0 ? -1 : 1, // left moves up, right moves down as offset grows
      cycle: 1,
      visible: true,
    }));

    // Buttons in duplicate sets shouldn't be tab-stops.
    gallery.querySelectorAll<HTMLElement>('[data-set][aria-hidden="true"] button')
      .forEach((b) => b.setAttribute('tabindex', '-1'));

    const WHEEL = 1;        // 1:1 wheel scroll — direct, no inertia
    const TOUCH = 1;        // finger tracks content 1:1
    const KEY_STEP = 420;   // keyboard nudge

    let offset = 0;
    let raf = 0;

    function measure() {
      for (const s of streams) {
        s.visible = s.track.offsetParent !== null; // false when display:none (mobile)
        const firstSet = s.track.querySelector<HTMLElement>('[data-set]');
        const h = firstSet ? firstSet.getBoundingClientRect().height : 0;
        s.cycle = h > 0 ? h : 1;
      }
    }
    measure();
    gallery.classList.add('is-ready');

    const overlayOpen = () => document.body.classList.contains('overlay-open');
    const wrap = (v: number, m: number) => ((v % m) + m) % m;

    // Write the current offset to the tracks. render() is pure; apply() is the
    // scheduled rAF callback; applyNow() forces a synchronous write (drag).
    function render() {
      for (const s of streams) {
        if (!s.visible) continue;
        const y = -s.cycle + s.dir * wrap(offset, s.cycle);
        s.track.style.transform = `translate3d(0, ${y}px, 0)`;
      }
    }
    function apply() { raf = 0; render(); }
    function schedule() { if (!raf) raf = requestAnimationFrame(apply); }
    function applyNow() {
      if (raf) { cancelAnimationFrame(raf); raf = 0; }
      render();
    }
    render();

    // ---- iOS-style momentum: 1:1 while the finger is down, then glide on
    // release with decaying velocity. Wheel/trackpad stay direct (the OS
    // already adds its own momentum to those). ----
    const FRICTION = 0.95;  // per ~16.7ms frame; higher = longer glide
    const MIN_V = 0.015;    // px/ms; below this the glide stops
    const MAX_V = 8;        // px/ms; clamp absurd flings
    let velocity = 0;       // px/ms, in offset units
    let momentumRaf = 0;
    let lastFrameT = 0;

    function stopMomentum() {
      if (momentumRaf) { cancelAnimationFrame(momentumRaf); momentumRaf = 0; }
      velocity = 0;
    }
    function momentumStep(now: number) {
      const dt = Math.min(now - lastFrameT, 50);
      lastFrameT = now;
      offset += velocity * dt;
      render();
      velocity *= Math.pow(FRICTION, dt / 16.67);
      if (Math.abs(velocity) < MIN_V) { momentumRaf = 0; velocity = 0; return; }
      momentumRaf = requestAnimationFrame(momentumStep);
    }
    function startMomentum() {
      if (Math.abs(velocity) < MIN_V) return;
      lastFrameT = performance.now();
      if (momentumRaf) cancelAnimationFrame(momentumRaf);
      momentumRaf = requestAnimationFrame(momentumStep);
    }

    gallery.addEventListener(
      'wheel',
      (e: WheelEvent) => {
        if (overlayOpen()) return;
        e.preventDefault();
        stopMomentum();
        offset += e.deltaY * WHEEL;
        schedule();
      },
      { passive: false }
    );

    let touchY = 0;
    let lastMoveT = 0;
    gallery.addEventListener(
      'touchstart',
      (e: TouchEvent) => {
        stopMomentum(); // catch the glide
        touchY = e.touches[0].clientY;
        lastMoveT = performance.now();
        measure(); // ensure the loop cycle is current at the start of the gesture
      },
      { passive: true }
    );
    gallery.addEventListener(
      'touchmove',
      (e: TouchEvent) => {
        if (overlayOpen()) return;
        const y = e.touches[0].clientY;
        const now = performance.now();
        const dy = (touchY - y) * TOUCH;
        offset += dy;
        touchY = y;
        const dt = now - lastMoveT;
        if (dt > 0) {
          velocity = Math.max(-MAX_V, Math.min(MAX_V, dy / dt)); // most-recent px/ms
        }
        lastMoveT = now;
        e.preventDefault();
        applyNow(); // sync transform to the finger
      },
      { passive: false }
    );
    gallery.addEventListener(
      'touchend',
      () => {
        // Only glide if the finger was still moving at lift-off.
        if (performance.now() - lastMoveT > 80) velocity = 0;
        startMomentum();
      },
      { passive: true }
    );

    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (overlayOpen()) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') {
        stopMomentum(); offset += KEY_STEP; e.preventDefault(); schedule();
      } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        stopMomentum(); offset -= KEY_STEP; e.preventDefault(); schedule();
      }
    });

    let resizeTimer: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { measure(); apply(); }, 150);
    });

    wireClicks(gallery);
  }

  function wireClicks(gallery: HTMLElement) {
    gallery.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const contact = target.closest('[data-contact]');
      if (contact) {
        document.dispatchEvent(new CustomEvent('ppc:open-contact'));
        return;
      }
      const project = target.closest<HTMLElement>('[data-project]');
      if (project) {
        document.dispatchEvent(
          new CustomEvent('ppc:open-project', { detail: project.dataset.project })
        );
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
</script>
