---
---
<div id="contact-form-wrapper">
  <form id="contact-form" novalidate>
    <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? ''} />
    <input type="hidden" name="subject" value="New brief — ppc.space" />
    <input type="hidden" name="from_name" value="PPC Website" />
    <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />

    <div class="space-y-4">
      <div class="form-field">
        <label for="name" class="label-text block mb-1">Name</label>
        <input
          type="text"
          name="name"
          id="name"
          required
          autocomplete="name"
          class="w-full border-b border-[var(--color-text)] bg-transparent py-2 font-baskerville text-base focus:outline-none focus:border-[var(--color-accent)] transition-colors placeholder:text-[var(--color-mute)]"
          placeholder=""
        />
      </div>

      <div class="form-field">
        <label for="email" class="label-text block mb-1">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          required
          autocomplete="email"
          class="w-full border-b border-[var(--color-text)] bg-transparent py-2 font-baskerville text-base focus:outline-none focus:border-[var(--color-accent)] transition-colors placeholder:text-[var(--color-mute)]"
          placeholder=""
        />
      </div>

      <div class="form-field">
        <label for="message" class="label-text block mb-1">Project / Message</label>
        <textarea
          name="message"
          id="message"
          rows={5}
          required
          class="w-full border-b border-[var(--color-text)] bg-transparent py-2 font-baskerville text-base focus:outline-none focus:border-[var(--color-accent)] transition-colors resize-none placeholder:text-[var(--color-mute)]"
          placeholder=""
        ></textarea>
      </div>

      <div class="pt-4">
        <button
          type="submit"
          id="submit-btn"
          class="font-barlow font-semibold uppercase tracking-[0.04em] text-sm border border-[var(--color-text)] px-6 py-3 hover:bg-[var(--color-text)] hover:text-[var(--color-bg)] transition-colors cursor-pointer"
        >
          Send →
        </button>
        <p id="form-error" class="mt-3 text-sm text-[var(--color-accent)] hidden">Something went wrong. Try again or email us directly.</p>
      </div>
    </div>
  </form>

  <div id="form-success" class="hidden">
    <p class="font-baskerville text-lg">Got it. We respond within 24 hours.</p>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const wrapper = document.getElementById('contact-form-wrapper');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.textContent = 'Sending…';
    submitBtn.disabled = true;
    errorEl?.classList.add('hidden');

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (json.success) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
      } else {
        throw new Error(json.message ?? 'Submission failed');
      }
    } catch {
      errorEl?.classList.remove('hidden');
      submitBtn.textContent = 'Send →';
      submitBtn.disabled = false;
    }
  });
</script>
