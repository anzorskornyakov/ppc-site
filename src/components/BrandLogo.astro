---
import type { Brand } from '../data/brands';

interface Props {
  brand: Brand;
}
const { brand } = Astro.props;

// Check is done at runtime client-side; we always render the img and fall back via onerror
---
<a
  href={brand.url}
  target="_blank"
  rel="noopener noreferrer"
  class="brand-logo-cell flex items-center justify-center p-4 border border-[var(--color-rule)] hover:border-[var(--color-text)] transition-colors min-h-[80px]"
  aria-label={brand.name}
  title={brand.name}
>
  <img
    src={`/brands/${brand.slug}.svg`}
    alt={brand.name}
    loading="lazy"
    width="120"
    height="40"
    class="max-w-[120px] max-h-[40px] object-contain"
    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
  />
  <span
    class="brand-name-fallback hidden items-center justify-center text-center text-sm leading-tight"
    aria-hidden="true"
  >
    {brand.name}
  </span>
</a>
