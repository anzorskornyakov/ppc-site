---
import { SITE } from '../data/site';

interface Props {
  active?: 'catalog' | 'studio' | null;
}
const { active = null } = Astro.props;

const nav = [
  { label: 'Screen printing', href: '/screen-printing' },
  { label: 'Embroidery', href: '/embroidery' },
  { label: 'DTF', href: '/dtf' },
  { label: 'Catalog', href: '/catalog', key: 'catalog' },
  { label: 'Studio', href: '/studio', key: 'studio' },
  { label: 'Contact', href: '/#contact' },
];
---
<header class="border-b border-[var(--color-rule)]">
  <!-- Announcement / utility bar -->
  <div class="border-b border-[var(--color-rule)] text-center py-1.5 px-4">
    <p class="text-[0.75rem] text-mute">
      Open for briefs · Lisbon ·
      <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">Message us on WhatsApp</a>
    </p>
  </div>

  <!-- Wordmark -->
  <div class="text-center pt-4 pb-2 px-4">
    <a href="/" class="plain-link inline-flex items-center gap-2.5" aria-label="PPC — home">
      <img src="/logo.svg" alt="" width="56" height="30" class="h-7 w-auto" />
      <span class="font-sans font-bold text-[1.25rem] tracking-tight">Portugal Print Club</span>
    </a>
  </div>

  <!-- Nav -->
  <nav aria-label="Primary" class="text-center pb-3 px-4">
    <ul class="inline-flex flex-wrap justify-center gap-x-3 gap-y-1 list-none text-[0.875rem]">
      {nav.map((item, i) => (
        <>
          {i > 0 && <li class="text-faint select-none" aria-hidden="true">·</li>}
          <li>
            <a
              href={item.href}
              class:list={['plain-link', item.key && active === item.key ? 'underline' : '']}
            >{item.label}</a>
          </li>
        </>
      ))}
    </ul>
  </nav>
</header>
