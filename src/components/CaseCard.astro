---
import type { Case } from '../data/cases';

interface Props { item: Case }
const { item } = Astro.props;

const isExpandable = Boolean(item.body) || (item.gallery?.length ?? 0) > 1;
const gallery = item.gallery && item.gallery.length > 0 ? item.gallery : [item.cover];
---
{isExpandable ? (
  <details class="case-card group">
    <summary class="case-summary">
      <img src={item.cover} alt={`${item.client} — ${item.technique}`} loading="lazy"
        class="w-full aspect-square object-cover border border-[var(--color-rule)] bg-[var(--color-surface)]" />
      <div class="mt-1.5 flex items-start justify-between gap-2">
        <p class="text-[0.875rem] leading-tight">
          <span class="font-bold">{item.client}</span><br />
          <span class="text-mute">{item.technique} · {item.item}</span>
        </p>
        <span class="case-toggle text-[var(--color-accent)] text-base leading-none shrink-0" aria-hidden="true">[+]</span>
      </div>
    </summary>

    <div class="case-body pt-3">
      {gallery.length > 1 && (
        <div class="flex gap-2 overflow-x-auto pb-1">
          {gallery.map((src, i) => (
            <img src={src} alt={`${item.client} — ${i + 1}`} loading="lazy"
              class="shrink-0 w-[70%] sm:w-[46%] aspect-square object-cover border border-[var(--color-rule)] bg-[var(--color-surface)]" />
          ))}
        </div>
      )}
      {item.body && <p class="prose-ppc text-[0.875rem] mt-3">{item.body}</p>}
      <p class="text-[0.8125rem] text-mute mt-2">
        {item.technique} · {item.item}{item.quantity ? ` · ${item.quantity}` : ''}
      </p>
    </div>
  </details>
) : (
  <div class="case-card">
    <img src={item.cover} alt={`${item.client} — ${item.technique}`} loading="lazy"
      class="w-full aspect-square object-cover border border-[var(--color-rule)] bg-[var(--color-surface)]" />
    <p class="mt-1.5 text-[0.875rem] leading-tight">
      <span class="font-bold">{item.client}</span><br />
      <span class="text-mute">{item.technique} · {item.item}</span>
    </p>
  </div>
)}

<style>
  .case-summary { list-style: none; cursor: pointer; }
  .case-summary::-webkit-details-marker { display: none; }
  details[open] .case-toggle::after { content: ""; }
  details[open] .case-toggle { /* swap [+] to [–] */ }
</style>

<script>
  // Swap [+]/[-] marker text on toggle (kept tiny + dependency-free)
  document.querySelectorAll('details.case-card').forEach((d) => {
    const t = d.querySelector('.case-toggle');
    if (!t) return;
    const sync = () => { t.textContent = d.open ? '[–]' : '[+]'; };
    sync();
    d.addEventListener('toggle', sync);
  });
</script>
