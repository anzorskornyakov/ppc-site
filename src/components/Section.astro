---
interface Props {
  id?: string;
  num?: string;
  label: string;
  class?: string;
}
const { id, label, class: className = '' } = Astro.props;
---
<section
  id={id}
  class:list={['divider py-8 md:py-10', className]}
>
  <div class="container-ppc">
    <p class="label-text mb-5">{label}</p>
    <slot />
  </div>
</section>
