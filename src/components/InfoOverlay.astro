---
import { SITE } from '../data/site';
import { services } from '../data/services';

const links = [
  { label: 'Catalog', href: '/catalog' },
  { label: 'Studio', href: '/studio' },
  ...services.map((s) => ({ label: s.name, href: s.path })),
];
---
<!-- Persistent, minimal chrome — no nav bar. Logo + Menu share one row,
     vertically centred to each other. -->
<div class="topbar">
  <a class="wordmark" href="/" aria-label={`${SITE.name} — home`}>
    <img src="/logo.webp" alt={SITE.name} width="116" height="54" />
  </a>
  <button type="button" class="menu-trigger" data-info-open aria-haspopup="dialog">Menu</button>
</div>

<!-- Persistent CTA on the gallery — opens the enquiry form -->
<button type="button" class="cta-fab" data-open-contact>Create new product</button>

<div class="info" id="info" role="dialog" aria-modal="true" aria-label="Menu" aria-hidden="true" hidden>
  <button type="button" class="info__close" data-info-close aria-label="Close">
    <span aria-hidden="true">×</span>
  </button>

  <div class="info__inner">
    <p class="info__statement">
      PPC is a creative merchandise production studio. We help brands turn ideas
      into high-quality products by selecting the most suitable garments and
      items for each project, then bringing them to life through premium printing
      and embroidery. When timing is critical, we can deliver complete projects
      in as little as 3 business days.
    </p>

    <button type="button" class="info__cta" data-start-project>Create new product</button>

    <nav class="info__nav" aria-label="Sections">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <ul class="info__contact">
      <li><span>Studio</span>{SITE.address.full} · {SITE.address.district}</li>
      <li><span>WhatsApp</span><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">{SITE.phone}</a></li>
      <li><span>Telegram</span><a href={SITE.telegramUrl} target="_blank" rel="noopener noreferrer">{SITE.telegram}</a></li>
      <li><span>Email</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      <li><span>Instagram</span><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer">{SITE.instagram}</a></li>
    </ul>
  </div>
</div>

<style>
  /* Top row: logo left, Menu right, both vertically centred to each other.
     pointer-events:none lets gallery scroll through the empty bar; the two
     interactive items re-enable pointer events. */
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 2rem) clamp(1rem, 5vw, 5rem);
    pointer-events: none;
  }
  .topbar > * { pointer-events: auto; }

  .wordmark { line-height: 0; }
  .wordmark img { height: clamp(2.75rem, 5.5vw, 4.5rem); width: auto; }

  .menu-trigger {
    border: 0;
    background: transparent;
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    cursor: pointer;
    padding: 0.25rem 0;
    transition: opacity 0.2s ease;
  }
  .menu-trigger:hover { opacity: 0.65; }

  /* Persistent enquiry CTA, styled like the PPC wordmark (blue oval) */
  .cta-fab {
    position: fixed;
    left: 50%;
    bottom: clamp(1.25rem, 4vw, 2.5rem);
    transform: translateX(-50%);
    z-index: 40;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    color: var(--color-accent);
    background: #fff;
    border: 2.5px solid var(--color-accent);
    border-radius: 50%;
    padding: 0.9rem 2.3rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .cta-fab:hover { background: var(--color-accent); color: #fff; }

  .info {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: #fff;
    overflow-y: auto;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .info.is-open { opacity: 1; }
  .info[hidden] { display: none; }

  .info__close {
    position: fixed;
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    width: 2.75rem; height: 2.75rem;
    display: flex; align-items: center; justify-content: center;
    border: 0; background: transparent;
    font-size: 2rem; line-height: 1;
    color: var(--color-text); cursor: pointer;
  }
  .info__close:hover { color: var(--color-accent); }

  .info__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(5rem, 16vh, 10rem) clamp(1.25rem, 6vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 6vh, 3.5rem);
  }
  .info__statement {
    font-size: clamp(1.0625rem, 2.2vw, 1.375rem);
    line-height: 1.45;
    margin: 0;
    color: var(--color-text);
  }

  /* Styled like the PPC wordmark: blue elliptical outline + blue text */
  .info__cta {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    color: var(--color-accent);
    background: transparent;
    border: 2.5px solid var(--color-accent);
    border-radius: 50%;
    padding: 0.95rem 2.4rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .info__cta:hover { background: var(--color-accent); color: #fff; }

  .info__nav ul { list-style: none; padding: 0; margin: 0; }
  .info__nav li { border-top: 1px solid var(--color-rule); }
  .info__nav li:last-child { border-bottom: 1px solid var(--color-rule); }
  .info__nav a {
    display: block;
    padding: 0.7rem 0;
    color: var(--color-text);
    text-decoration: none;
    font-size: 1rem;
  }
  .info__nav a:hover { color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px; }

  .info__contact { list-style: none; padding: 0; margin: 0; font-size: 0.9375rem; }
  .info__contact li { margin-bottom: 0.4rem; color: var(--color-text); }
  .info__contact span { display: inline-block; width: 6rem; color: var(--color-mute); }
</style>

<script>
  function initInfo() {
    const info = document.getElementById('info');
    const trigger = document.querySelector<HTMLButtonElement>('[data-info-open]');
    if (!info || !trigger) return;
    let lastFocus: HTMLElement | null = null;

    function open() {
      lastFocus = document.activeElement as HTMLElement;
      info!.hidden = false;
      info!.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overlay-open');
      requestAnimationFrame(() => info!.classList.add('is-open'));
      info!.querySelector<HTMLElement>('[data-info-close]')?.focus();
    }
    function close() {
      info!.classList.remove('is-open');
      document.body.classList.remove('overlay-open');
      window.setTimeout(() => {
        info!.hidden = true;
        info!.setAttribute('aria-hidden', 'true');
      }, 300);
      lastFocus?.focus();
    }

    trigger.addEventListener('click', open);
    document.querySelector('[data-open-contact]')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('ppc:open-contact'));
    });
    info.querySelector('[data-start-project]')?.addEventListener('click', () => {
      close();
      window.setTimeout(() => document.dispatchEvent(new CustomEvent('ppc:open-contact')), 300);
    });
    info.querySelector('[data-info-close]')?.addEventListener('click', close);
    info.addEventListener('click', (e) => { if (e.target === info) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !info.hidden) close();
    });
    document.addEventListener('ppc:open-info', open);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInfo);
  } else {
    initInfo();
  }
</script>
