---
import { SITE } from '../data/site';
import { services } from '../data/services';

interface Props {
  /** Render the menu open in the static HTML (homepage). False = start closed (e.g. /gallery). */
  defaultOpen?: boolean;
  /** Render the lead line as the page <h1>. Set false when the page has its own h1. */
  primary?: boolean;
}
const { defaultOpen = true, primary = true } = Astro.props;
---
<!-- Top chrome over the gallery (visible when the menu is closed) -->
<div class="topbar">
  <a class="wordmark" href="/" aria-label={`${SITE.name} — home`}>
    <img src="/logo.webp" alt={SITE.name} width="116" height="54" />
  </a>
  <button type="button" class="menu-trigger" data-info-open aria-haspopup="dialog">Menu</button>
</div>

<!-- Persistent CTA on the gallery — opens the menu's brief form -->
<button type="button" class="cta-fab" data-open-contact>Create new product</button>

<!-- On the homepage the menu is rendered OPEN in static HTML so the h1 and copy
     are crawlable by bots that don't execute JS. On other pages (e.g. /gallery)
     it starts closed and is opened with the "Menu" trigger. -->
<div class:list={['info', defaultOpen && 'is-open']} id="info" role="dialog" aria-modal="true" aria-label="Menu" aria-hidden={defaultOpen ? 'false' : 'true'} hidden={!defaultOpen} data-default-open={String(defaultOpen)}>
  <button type="button" class="info__close" data-info-close aria-label="Close menu">
    <span aria-hidden="true">×</span>
  </button>

  <div class="info__inner">
    <img class="info__logo" src="/logo.webp" alt={SITE.name} width="160" height="74" />

    <div class="info__about">
      {primary ? (
        <h1 class="info__lead">We help brands create and produce merch.</h1>
      ) : (
        <p class="info__lead">We help brands create and produce merch.</p>
      )}
      <p>Design, product selection, printing, embroidery, and production management — all under one roof.</p>
      <p>Fast turnaround — 3 business days.</p>
    </div>

    <nav class="info__buttons" aria-label="Sections">
      <a class="info__btn info__btn--primary" href="/gallery">
        <span class="info__btn__label">Recent Works</span>
        <span class="info__btn__desc">See the merch we've made</span>
      </a>
      <a class="info__btn" href="/catalog">
        <span class="info__btn__label">Catalog</span>
        <span class="info__btn__desc">Blanks and garments to print on</span>
      </a>
      <a class="info__btn" href="/studio">
        <span class="info__btn__label">Studio</span>
        <span class="info__btn__desc">Visit our space in central Lisbon</span>
      </a>
    </nav>

    <section class="info__brief" id="brief">
      <button type="button" class="info__btn info__btn--primary" data-open-contact>
        <span class="info__btn__label">Create new product</span>
        <span class="info__btn__desc">Tell us about your project</span>
      </button>
    </section>

    <nav class="info__links" aria-label="Techniques">
      {services.map((s) => <a href={s.path}>{s.name}</a>)}
    </nav>

    <ul class="info__contact">
      <li><span>Studio</span>{SITE.address.full} · {SITE.address.district}</li>
      <li><span>WhatsApp</span><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">Message us</a></li>
      <li><span>Telegram</span><a href={SITE.telegramUrl} target="_blank" rel="noopener noreferrer">{SITE.telegram}</a></li>
      <li><span>Email</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      <li><span>Instagram</span><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer">{SITE.instagram}</a></li>
    </ul>

    <p class="info__legal">{SITE.legalName} · NIPC {SITE.nipc} · VAT {SITE.vatId}</p>
  </div>
</div>

<style>
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 3vw, 2rem) clamp(1rem, 5vw, 5rem);
    pointer-events: none;
  }
  .topbar > * { pointer-events: auto; }
  .wordmark { line-height: 0; }
  .wordmark img { height: clamp(2.75rem, 5.5vw, 4.5rem); width: auto; }

  .menu-trigger {
    border: 0; background: transparent;
    font-size: 0.875rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--color-accent); cursor: pointer;
    padding: 0.25rem 0; transition: opacity 0.2s ease;
  }
  .menu-trigger:hover { opacity: 0.65; }

  .cta-fab {
    position: fixed;
    left: 50%; bottom: clamp(1.25rem, 4vw, 2.5rem);
    transform: translateX(-50%);
    z-index: 40;
    font-family: var(--font-sans); font-weight: 700;
    font-size: 0.9375rem; letter-spacing: 0.02em; white-space: nowrap;
    color: var(--color-accent); background: #fff;
    border: 2.5px solid var(--color-accent); border-radius: 50%;
    padding: 0.9rem 2.3rem; cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .cta-fab:hover { background: var(--color-accent); color: #fff; }

  .info {
    position: fixed; inset: 0; z-index: 60;
    /* Frosted glass — much more transparent so the gallery reads through clearly */
    background: rgba(255, 255, 255, 0.38);
    backdrop-filter: blur(22px) saturate(1.08);
    -webkit-backdrop-filter: blur(22px) saturate(1.08);
    overflow-y: auto;
    opacity: 0; transition: opacity 0.4s ease;
  }
  .info.is-open { opacity: 1; }
  .info[hidden] { display: none; }

  .info__close {
    position: fixed;
    top: clamp(1rem, 3vw, 2rem); right: clamp(1rem, 3vw, 2rem);
    width: 2.75rem; height: 2.75rem;
    display: flex; align-items: center; justify-content: center;
    border: 0; background: transparent;
    font-size: 2rem; line-height: 1;
    color: var(--color-text); cursor: pointer; z-index: 2;
  }
  .info__close:hover { color: var(--color-accent); }

  .info__inner {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(4rem, 11vh, 7rem) clamp(1.25rem, 6vw, 3rem) clamp(3.5rem, 9vh, 5.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 6vh, 4rem);
  }
  .info__logo {
    align-self: center;        /* center the mark without stretching it */
    height: clamp(3.25rem, 8vw, 5rem);   /* brand mark gets presence */
    width: auto;
    max-width: 100%;
  }

  /* Flat, uniform copy — one standard weight/size for all lines */
  .info__about {
    text-align: center;
    max-width: 46ch;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .info__about > * {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.7vw, 1.1875rem);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--color-text);
    text-wrap: pretty;
  }

  /* Three primary destinations — plain text, no frame. Same type as the copy
     above, just a larger tap area. Gallery's label is accent blue. */
  .info__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .info__btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    padding: 0.7rem 1.5rem;     /* generous tap area without any box */
    border: 0;
    background: transparent;
    color: var(--color-text);
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }
  .info__btn:hover { opacity: 0.55; }
  .info__btn__label {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.7vw, 1.1875rem);  /* matches the about block */
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.3;
  }
  .info__btn__desc {
    font-size: 0.8125rem;
    color: var(--color-mute);
    line-height: 1.25;
  }
  .info__btn--primary .info__btn__label { color: var(--color-accent); }

  .info__brief {
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--color-rule);
    padding-top: clamp(1.5rem, 3.5vh, 2rem);
  }

  .info__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .info__links a { font-size: 0.9375rem; color: var(--color-text); }

  .info__contact { list-style: none; padding: 0; margin: 0; font-size: 0.9375rem; }
  .info__contact li { margin-bottom: 0.4rem; color: var(--color-text); }
  .info__contact span { display: inline-block; width: 6rem; color: var(--color-mute); }

  .info__legal {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-faint);
  }
</style>

<script>
  function initInfo() {
    const info = document.getElementById('info');
    if (!info) return;
    let lastFocus: HTMLElement | null = null;

    function open(focus = true) {
      lastFocus = document.activeElement as HTMLElement;
      info!.hidden = false;
      info!.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overlay-open');
      requestAnimationFrame(() => info!.classList.add('is-open'));
      if (focus) info!.querySelector<HTMLElement>('[data-info-close]')?.focus();
    }
    function close() {
      info!.classList.remove('is-open');
      document.body.classList.remove('overlay-open');
      window.setTimeout(() => {
        info!.hidden = true;
        info!.setAttribute('aria-hidden', 'true');
      }, 300);
      lastFocus?.focus();
    }
    document.querySelector('[data-info-open]')?.addEventListener('click', () => open());
    // X and the "Gallery" card both just close the menu (revealing the gallery)
    info.querySelectorAll('[data-info-close]').forEach((el) =>
      el.addEventListener('click', () => close())
    );
    info.addEventListener('click', (e) => { if (e.target === info) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !info.hidden) close();
    });

    // Keep keyboard focus inside the menu while it's open.
    info.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || info!.hidden) return;
      const f = Array.from(info!.querySelectorAll<HTMLElement>(
        'a[href],button:not([disabled]),input,textarea,select,[tabindex]:not([tabindex="-1"])'
      )).filter((el) => el.offsetParent !== null);
      if (!f.length) return;
      const first = f[0], last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });

    // "Create new product" triggers are handled by CreateProduct (the modal).
    document.addEventListener('ppc:open-info', () => open());

    const startOpen = info.dataset.defaultOpen !== 'false';

    if (location.hash.startsWith('#project/')) {
      // Old deep link — ProjectOverlay redirects it to /work/<slug>; do nothing.
    } else if (location.hash) {
      // A hash like #create opens the brief modal — keep the menu closed behind it.
      if (startOpen) {
        info.classList.remove('is-open');
        info.hidden = true;
        info.setAttribute('aria-hidden', 'true');
      }
    } else if (startOpen) {
      document.body.classList.add('overlay-open');
      // The menu is a persistent scroll container now, so the browser may
      // restore a previous scroll position. Always open it from the top.
      info.scrollTop = 0;
      requestAnimationFrame(() => { info.scrollTop = 0; });
    }
    // startOpen=false (e.g. /gallery): menu stays closed; "Menu" opens it.
  }

  // Browsers restore scroll positions (incl. nested containers) on history nav.
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInfo);
  } else {
    initInfo();
  }
  // bfcache restores (back/forward) re-run pageshow, not the script.
  window.addEventListener('pageshow', () => {
    const info = document.getElementById('info');
    if (info && !info.hidden && !location.hash) info.scrollTop = 0;
  });
</script>
