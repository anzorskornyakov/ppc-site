---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import SEO from './SEO.astro';
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  sectionNum: string;
  title: string;
  subtitle: string;
  metaTitle: string;
  metaDescription: string;
  ogImage: string;
  canonicalUrl: string;
  schemas: object[];
  breadcrumbs: { name: string; href?: string }[];
}

const {
  sectionNum,
  title,
  subtitle,
  metaTitle,
  metaDescription,
  ogImage,
  canonicalUrl,
  schemas,
  breadcrumbs,
} = Astro.props;
---
<Base title={metaTitle} description={metaDescription}>
  <SEO
    slot="head"
    title={metaTitle}
    description={metaDescription}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
    schemas={schemas}
  />

  <Header />

  <main>
    <Breadcrumbs items={breadcrumbs} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Page title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Technique</p>
        <h1 class="text-display mb-6 max-w-4xl">{title}</h1>
        <p class="lede text-mute">{subtitle}</p>
      </div>

      <!-- Page content sections -->
      <div class="service-content space-y-14">
        <slot />
      </div>

      <!-- CTA block -->
      <div class="mt-20 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href="/#contact" class="btn-solid">Send a brief →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
