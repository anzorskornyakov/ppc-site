---
import { SITE } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-rule)] mt-12">
  <div class="container-ppc py-8 text-center">
    <p class="text-[0.875rem] mb-3">
      <a href="/gallery">Gallery</a> ·
      <a href="/catalog">Catalog</a> ·
      <a href="/studio">Studio</a> ·
      <a href="/screen-printing">Screen printing</a> ·
      <a href="/embroidery">Embroidery</a> ·
      <a href="/dtf">DTF</a> ·
      <a href="/#create">Contact</a>
    </p>
    <p class="text-[0.875rem] mb-4">
      <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a> ·
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a> ·
      <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
    </p>
    <p class="section-num">
      © {year} {SITE.legalName} · NIPC {SITE.nipc} · {SITE.address.city}, {SITE.address.country} · Prices exclude 23% VAT
    </p>
  </div>
</footer>
