---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RequestForm from '../components/RequestForm.astro';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/contact`;
const metaDescription =
  'Start a project with PPC — custom printing and embroidery in Lisbon. Send a brief and we reply within one business day.';
---
<Base title="Start a project — PPC" description={metaDescription}>
  <SEO
    slot="head"
    title="Start a project — PPC"
    description={metaDescription}
    ogImage="/og-default.jpg"
    canonicalUrl={canonicalUrl}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Contact' }]} />

    <div class="container-ppc pt-10 pb-24">
      <div class="mb-12 pb-8 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Contact</p>
        <h1 class="text-display mb-5">Start a project</h1>
        <p class="lede text-mute max-w-[42rem]">
          Tell us what you're working on. We reply within one business day with a
          technique recommendation, blank options and a precise quote.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div>
          <RequestForm />
        </div>

        <div class="contact-aside">
          <p class="label-text mb-3">Direct</p>
          <ul class="contact-channels">
            <li><span>WhatsApp</span><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">{SITE.phone}</a></li>
            <li><span>Telegram</span><a href={SITE.telegramUrl} target="_blank" rel="noopener noreferrer">{SITE.telegram}</a></li>
            <li><span>Email</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
            <li><span>Instagram</span><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer">{SITE.instagram}</a></li>
          </ul>

          <p class="label-text mt-8 mb-3">Studio</p>
          <p class="prose-ppc text-mute">
            {SITE.address.full}<br />
            {SITE.address.district}, Lisbon<br />
            By appointment · {SITE.hours.weekdays}
          </p>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <style>
    .contact-channels { list-style: none; padding: 0; margin: 0; font-size: 0.9375rem; }
    .contact-channels li { margin-bottom: 0.4rem; }
    .contact-channels span { display: inline-block; width: 6rem; color: var(--color-mute); }
  </style>
</Base>
