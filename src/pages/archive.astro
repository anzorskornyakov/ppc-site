---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
import Gallery from '../components/Gallery.astro';
import ProjectOverlay from '../components/ProjectOverlay.astro';
import InfoOverlay from '../components/InfoOverlay.astro';
import { SITE } from '../data/site';
import { cases } from '../data/cases';

const canonicalUrl = `${SITE.url}/archive`;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${canonicalUrl}#work`,
  name: 'PPC Archive — selected work',
  itemListElement: cases.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: `${c.client} — ${c.item}`,
      about: c.technique,
      url: `${canonicalUrl}#project/${c.slug}`,
    },
  })),
};
---
<Base
  title="Archive — PPC's work"
  description="The PPC archive — custom merch and uniforms made in Lisbon: screen printing, embroidery and DTF for cafés, brands and bands."
>
  <SEO
    slot="head"
    title="Archive — PPC's work"
    description="The PPC archive — custom merch and uniforms made in Lisbon: screen printing, embroidery and DTF for cafés, brands and bands."
    ogImage="/og-default.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[itemListSchema]}
  />

  <InfoOverlay />
  <Gallery />
  <ProjectOverlay />

  <!-- Lock the document on the gallery page so iOS can't rubber-band /
       pull-to-refresh and fight the gallery's own scroll. -->
  <style is:global>
    html, body {
      height: 100%;
      overflow: hidden;
      overscroll-behavior: none;
    }
    body {
      position: fixed;
      inset: 0;
      width: 100%;
    }
  </style>
</Base>
