---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CreateProduct from '../components/CreateProduct.astro';
import { services } from '../data/services';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/services`;
const title = 'Services — printing & embroidery in Lisbon | PPC';
const description =
  'PPC services in Lisbon: custom screen printing, embroidery and DTF printing. From 1 piece, ready in 3 business days. Studio in Campolide.';

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${canonicalUrl}#services`,
  name: 'PPC services',
  numberOfItems: services.length,
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'Service', name: s.name, url: `${SITE.url}${s.path}` },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'PPC', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Services', item: canonicalUrl },
  ],
};
---
<Base title={title} description={description}>
  <SEO
    slot="head"
    title={title}
    description={description}
    ogImage="/og-default.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[itemListSchema, breadcrumbSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Services' }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">What we do</p>
        <h1 class="text-display mb-6">Services</h1>
        <p class="lede text-mute">
          Screen printing, embroidery and DTF — produced in our Lisbon studio,
          ready in 3 business days.
        </p>
      </div>

      <!-- Services grid -->
      <div class="services-grid">
        {services.map((s) => (
          <a class="service-card" href={s.path}>
            <h2 class="service-card__name">{s.name}</h2>
            <p class="service-card__sub">{s.subtitle}</p>
            <dl class="service-card__facts">
              <div><dt>From</dt><dd>{s.minOrder}</dd></div>
              <div><dt>Turnaround</dt><dd>{s.turnaround}</dd></div>
              <div><dt>Price</dt><dd>€{s.priceLow}–{s.priceHigh} / pc</dd></div>
            </dl>
            <span class="service-card__link">Learn more →</span>
          </a>
        ))}
      </div>

      <!-- CTA block -->
      <div class="mt-20 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href="/#create" data-open-contact class="btn-cta">Create new product →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <CreateProduct />
  <Footer />
</Base>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
  }
  @media (min-width: 760px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }
  .service-card:hover { background: var(--color-surface); }
  .service-card__name {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .service-card__sub {
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-mute);
    flex: 1 1 auto;
  }
  .service-card__facts {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--color-rule);
  }
  .service-card__facts > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.8125rem;
  }
  .service-card__facts dt { color: var(--color-mute); }
  .service-card__facts dd { margin: 0; color: var(--color-text); }
  .service-card__link {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-accent);
  }
</style>
