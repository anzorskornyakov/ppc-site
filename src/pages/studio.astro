---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/studio`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
    `${SITE.url}/photos/studio-detail-02.jpg`,
    `${SITE.url}/photos/studio-detail-03.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
  ],
};

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  '@id': `${canonicalUrl}#place`,
  name: 'PPC Studio',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  hasMap: `https://www.google.com/maps/place/Cal%C3%A7ada+dos+Mestres+34,+Lisboa`,
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: 'Campolide, Lisboa, Portugal',
  },
};

// Photos coming soon — clean labelled placeholders for now.
const studioPhotos = [
  { label: 'Garment & blank racks' },
  { label: 'Past prints & designs' },
  { label: 'Screen printing carousel' },
  { label: 'Embroidery machine' },
  { label: 'Design & sample table' },
  { label: 'The studio floor' },
];
---
<Base
  title="The PPC studio — a creative print space in central Lisbon"
  description="A creative space in central Lisbon: choose garments, browse designs, handle samples. Open weekdays, visits by appointment via email. Campolide, 5 min from Marquês de Pombal."
>
  <SEO
    slot="head"
    title="The PPC studio — a creative print space in central Lisbon"
    description="A creative space in central Lisbon: choose garments, browse designs, handle samples. Open weekdays, visits by appointment via email. Campolide, 5 min from Marquês de Pombal."
    ogImage="/og-studio.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[localBusinessSchema, placeSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Studio' }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Studio</p>
        <h1 class="text-display mb-6">A creative space, not just a print shop</h1>
        <p class="lede text-mute">
          A studio in central Lisbon where you can choose garments, browse
          past designs and prints, handle samples, and shape your project
          with us in the room — then watch it get made.
        </p>
      </div>

      <!-- Hero placeholder -->
      <figure class="mb-16">
        <div class="w-full aspect-[16/8] bg-[var(--color-surface)] border border-[var(--color-rule)] flex items-center justify-center">
          <span class="section-num">The studio floor — photo coming soon</span>
        </div>
        <figcaption class="section-num mt-3">Fig. 01 — Calçada dos Mestres 34, Lisbon</figcaption>
      </figure>

      <div class="divide-y divide-[var(--color-rule)] border-t border-[var(--color-rule)]">

        <!-- A creative space -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">The space</p>
          <div>
            <div class="prose-ppc mb-8">
              <p>
                PPC isn't just a production floor — it's a place to make
                things. Come in to pick out blanks and garments, feel the
                difference between fabrics and weights, flip through past
                prints and designs, and figure out what actually works for
                your idea, together with us.
              </p>
              <p>
                It's also where everything gets made: a 6-colour screen
                printing carousel, an embroidery machine, a DTF printer, a
                heat press, sample racks, and a worktable for design and
                conversation. Approvals happen with the real thing in
                hand — not over email.
              </p>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
              {studioPhotos.map((photo, i) => (
                <figure class="aspect-[4/3] bg-[var(--color-surface)] border border-[var(--color-rule)] flex items-center justify-center p-3 relative">
                  <span class="section-num text-center">{photo.label}</span>
                  <figcaption class="absolute bottom-2 left-2 section-num text-mute">{String(i + 2).padStart(2, '0')}</figcaption>
                </figure>
              ))}
            </div>
            <p class="section-num mt-3">Photos coming soon.</p>
          </div>
        </div>

        <!-- Location -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Location</p>
          <div>
            <address class="not-italic prose-ppc mb-3">
              <span class="block">{SITE.address.street}</span>
              <span class="block">{SITE.address.postal} {SITE.address.city}, {SITE.address.country}</span>
              <span class="block">{SITE.address.district}</span>
            </address>
            <p class="prose-ppc">
              We're almost in the centre of Lisbon, in Campolide — about
              five minutes on foot from Marquês de Pombal, and easy to
              reach by metro, bus or car. Ground floor, street entrance,
              letter A.
            </p>
          </div>
        </div>

        <!-- Hours & visits -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Hours & visits</p>
          <div>
            <dl class="mb-6">
              <div class="spec-row">
                <dt class="spec-key">Monday — Friday</dt>
                <dd class="spec-val">10:00 — 19:00</dd>
              </div>
              <div class="spec-row">
                <dt class="spec-key">Saturday — Sunday</dt>
                <dd class="spec-val">By appointment</dd>
              </div>
            </dl>
            <p class="prose-ppc">
              Visits are by appointment so we can give you our full
              attention. Write to us at
              <a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>
              to arrange a time — a typical visit is 30 to 60 minutes.
              Bring your brief if you have one.
            </p>
          </div>
        </div>

        <!-- Contact -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Contact</p>
          <dl>
            <div class="spec-row">
              <dt class="spec-key">Email</dt>
              <dd class="spec-val"><a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">WhatsApp</dt>
              <dd class="spec-val"><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Instagram</dt>
              <dd class="spec-val"><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a></dd>
            </div>
          </dl>
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href={`mailto:${SITE.email}?subject=Studio%20visit`} class="btn-solid">Email to book a visit →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
