---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/studio`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
    `${SITE.url}/photos/studio-detail-02.jpg`,
    `${SITE.url}/photos/studio-detail-03.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
  ],
};

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  '@id': `${canonicalUrl}#place`,
  name: 'PPC Studio',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  hasMap: `https://www.google.com/maps/place/Cal%C3%A7ada+dos+Mestres+34,+Lisboa`,
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: 'Campolide, Lisboa, Portugal',
  },
};

const studioPhotos = [
  { src: '/photos/studio-detail-01.jpg', alt: '6-color screen printing carousel at PPC studio' },
  { src: '/photos/studio-detail-02.jpg', alt: 'Single-head industrial embroidery machine at PPC' },
  { src: '/photos/studio-detail-03.jpg', alt: 'DTF printer at PPC studio' },
];
---
<Base
  title="Visit the PPC studio — Calçada dos Mestres 34, Lisbon"
  description="Visit Portugal Print Club in Campolide, Lisbon. See screen printing, embroidery, and DTF in person. By appointment."
>
  <SEO
    slot="head"
    title="Visit the PPC studio — Calçada dos Mestres 34, Lisbon"
    description="Visit Portugal Print Club in Campolide, Lisbon. See screen printing, embroidery, and DTF in person. By appointment."
    ogImage="/og-studio.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[localBusinessSchema, placeSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Studio' }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Studio</p>
        <h1 class="text-display mb-6">Studio</h1>
        <p class="lede text-mute">
          A custom print studio in Campolide, Lisbon. Open for client
          visits by appointment.
        </p>
      </div>

      <!-- Hero photo -->
      <figure class="mb-16">
        <div class="w-full aspect-[16/8] overflow-hidden bg-[rgba(20,17,14,0.06)]">
          <img src="/photos/studio-hero.jpg" alt="PPC studio interior — Calçada dos Mestres 34, Lisbon" loading="lazy" class="w-full h-full object-cover" />
        </div>
        <figcaption class="section-num mt-3">Fig. 01 — The studio floor, Calçada dos Mestres 34</figcaption>
      </figure>

      <div class="divide-y divide-[var(--color-rule)] border-t border-[var(--color-rule)]">

        <!-- Address -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Address</p>
          <div>
            <address class="not-italic prose-ppc mb-3">
              <span class="block">{SITE.address.street}</span>
              <span class="block">{SITE.address.postal} {SITE.address.city}, {SITE.address.country}</span>
              <span class="block">{SITE.address.district}</span>
            </address>
            <p class="prose-ppc text-mute text-sm">Ground floor. Street entrance, letter A. Five minutes from Marquês de Pombal on foot.</p>
          </div>
        </div>

        <!-- About the space -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">About the space</p>
          <div>
            <div class="prose-ppc mb-8">
              <p>This is where we work and where we meet clients.</p>
              <p>
                Inside: a 6-colour screen printing carousel, a single-head
                embroidery machine, a DTF printer, a heat press, sample fabric
                racks, and a worktable for design and conversation.
              </p>
              <p>
                We invite clients in. See samples, handle blanks, understand
                what each technique actually looks like in person, and meet
                the people making your order. Approvals happen with the real
                thing in hand — not over email.
              </p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
              {studioPhotos.map((photo, i) => (
                <figure class="aspect-[4/3] overflow-hidden bg-[rgba(20,17,14,0.06)] relative group">
                  <img src={photo.src} alt={photo.alt} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
                  <figcaption class="absolute bottom-2 left-2 section-num text-[var(--color-bg)] mix-blend-difference">{String(i + 2).padStart(2, '0')}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </div>

        <!-- How to visit -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">How to visit</p>
          <div class="prose-ppc">
            <p>
              Studio visits are by appointment. Book ahead via WhatsApp or
              email — a typical visit is 30 to 60 minutes.
            </p>
            <p>
              Bring your brief if you have one. We keep samples of every
              technique, fabric weight and blank on file.
            </p>
          </div>
        </div>

        <!-- Hours -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Hours</p>
          <dl>
            <div class="spec-row">
              <dt class="spec-key">Monday — Friday</dt>
              <dd class="spec-val">10:00 — 19:00</dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Saturday — Sunday</dt>
              <dd class="spec-val">By appointment</dd>
            </div>
          </dl>
        </div>

        <!-- Contact -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Contact</p>
          <dl>
            <div class="spec-row">
              <dt class="spec-key">WhatsApp</dt>
              <dd class="spec-val"><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Email</dt>
              <dd class="spec-val"><a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Instagram</dt>
              <dd class="spec-val"><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a></dd>
            </div>
          </dl>
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href="/contact" class="btn-solid">Send a brief →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
