---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/studio`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio/studio-floor.webp`,
    `${SITE.url}/photos/studio/studio-screenprint.webp`,
    `${SITE.url}/photos/studio/studio-embroidery.webp`,
    `${SITE.url}/photos/studio/studio-racks.webp`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
  ],
};

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  '@id': `${canonicalUrl}#place`,
  name: 'PPC Studio',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  hasMap: `https://www.google.com/maps/place/Cal%C3%A7ada+dos+Mestres+34,+Lisboa`,
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: 'Campolide, Lisboa, Portugal',
  },
};

// Studio photos (priority order).
const studioPhotos = [
  { src: '/photos/studio/studio-racks.webp', label: 'Garments & blanks on the rack' },
  { src: '/photos/studio/studio-screenprint.webp', label: 'Screen printing carousel' },
  { src: '/photos/studio/studio-embroidery.webp', label: 'Embroidery machine' },
  { src: '/photos/studio/studio-desk.webp', label: 'Design & sample corner' },
];

// Directions from the visitor's current location to the studio.
const mapsDir = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(
  `${SITE.address.street}, ${SITE.address.postal} ${SITE.address.city}, ${SITE.address.country}`
)}`;
---
<Base
  title="Visit the PPC studio — merch development in Lisbon"
  description="A studio built for merch development in Campolide, Lisbon. Compare garments, review samples and past projects, and choose products before production. Open studio sessions for creators. Book a visit by email."
>
  <SEO
    slot="head"
    title="Visit the PPC studio — merch development in Lisbon"
    description="A studio built for merch development in Campolide, Lisbon. Compare garments, review samples and past projects, and choose products before production. Open studio sessions for creators. Book a visit by email."
    ogImage="/og-studio.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[localBusinessSchema, placeSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Studio' }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Hero / title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Studio</p>
        <h1 class="text-display mb-6">A studio built for merch development</h1>
        <div class="lede text-mute space-y-4">
          <p>
            Our studio is open to clients, brands, agencies, and creators who
            want to work on products in person. Visit the studio to compare
            garments, review samples, explore previous projects, and choose
            the right products and production methods for your needs.
          </p>
          <p>
            Everything can be discussed, tested, and approved on site before
            production begins.
          </p>
        </div>
      </div>

      <!-- Hero -->
      <figure class="mb-16">
        <div class="w-full aspect-[16/8] overflow-hidden bg-[var(--color-surface)]">
          <img src="/photos/studio/studio-floor.webp" alt="The PPC studio floor in Campolide, Lisbon" width="1448" height="1086" loading="eager" class="w-full h-full object-cover" />
        </div>
        <figcaption class="section-num mt-3">Calçada dos Mestres 34, Campolide, Lisbon</figcaption>
      </figure>

      <div class="divide-y divide-[var(--color-rule)] border-t border-[var(--color-rule)]">

        <!-- The space -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">The space</p>
          <div>
            <div class="prose-ppc mb-8">
              <p>The studio is designed to help clients make better product decisions.</p>
              <p>
                Browse garments and blanks, compare fabrics and weights,
                review embroidery and print samples, and discuss ideas with
                our team before placing an order.
              </p>
              <p>
                We regularly work with brands, creative teams, designers, and
                independent creators who want to develop products in person
                rather than through emails and PDFs.
              </p>
              <p>
                Production happens here too. Screen printing, embroidery, DTF
                printing, sampling, and product development all take place
                under one roof, allowing you to review physical samples and
                make decisions with the actual product in front of you.
              </p>
            </div>
            <div class="grid grid-cols-2 gap-2">
              {studioPhotos.map((photo) => (
                <figure>
                  <div class="aspect-[4/3] overflow-hidden bg-[var(--color-surface)]">
                    <img src={photo.src} alt={photo.label} loading="lazy" decoding="async" class="w-full h-full object-cover" />
                  </div>
                  <figcaption class="section-num mt-2">{photo.label}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Location</p>
          <div>
            <address class="not-italic prose-ppc mb-3">
              <span class="block">{SITE.address.street}</span>
              <span class="block">{SITE.address.postal} {SITE.address.city}, {SITE.address.country}</span>
            </address>
            <p class="prose-ppc mb-5">
              The studio is located in Campolide, close to the centre of
              Lisbon. Ground-floor entrance, letter A.
            </p>
            <a href={mapsDir} target="_blank" rel="noopener noreferrer" class="btn-ghost">Open in Google Maps →</a>
          </div>
        </div>

        <!-- Visits & consultations -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Visits & consultations</p>
          <div>
            <div class="prose-ppc mb-6">
              <p>
                Visits are scheduled in advance so we can dedicate time to
                your project.
              </p>
              <p>
                Whether you need help selecting products, reviewing samples,
                discussing design ideas, or planning production, we recommend
                booking a visit before placing an order. Most visits take
                between 30 and 60 minutes.
              </p>
            </div>
            <p class="prose-ppc">
              To arrange a visit, email
              <a href={`mailto:${SITE.email}?subject=Studio%20visit`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>.
            </p>
          </div>
        </div>

        <!-- Open studio sessions -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Open studio sessions</p>
          <div>
            <div class="prose-ppc mb-6">
              <p>
                We offer bookable studio sessions for designers, creators, and
                makers who want access to professional equipment and workspace.
              </p>
              <p>
                Open sessions are available in 2–3 hour blocks and can be used
                for sampling, testing ideas, learning equipment, developing
                products, or working on personal projects. Equipment
                availability depends on the session and project requirements.
              </p>
              <p>Sessions must be booked in advance.</p>
            </div>
            <p class="prose-ppc">
              To check availability and book a session, email
              <a href={`mailto:${SITE.email}?subject=Open%20studio%20session`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>.
            </p>
          </div>
        </div>

        <!-- Contact -->
        <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 py-10">
          <p class="label-text mb-4 md:mb-0">Contact</p>
          <dl>
            <div class="spec-row">
              <dt class="spec-key">Email</dt>
              <dd class="spec-val"><a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">WhatsApp</dt>
              <dd class="spec-val"><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a></dd>
            </div>
            <div class="spec-row">
              <dt class="spec-key">Instagram</dt>
              <dd class="spec-val"><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a></dd>
            </div>
          </dl>
        </div>

      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href={`mailto:${SITE.email}?subject=Studio%20visit`} class="btn-solid">Book a Visit →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
