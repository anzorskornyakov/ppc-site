---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BrandLogo from '../components/BrandLogo.astro';
import StructuredData from '../components/StructuredData.astro';
import { brands, tierLabels, tierOrder } from '../data/brands';
import { SITE } from '../data/site';

const canonicalUrl = `${SITE.url}/catalog`;

const brandsByTier = tierOrder.map((tier) => ({
  tier,
  meta: tierLabels[tier],
  brands: brands.filter((b) => b.tier === tier),
}));

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${canonicalUrl}#brands`,
  name: 'Blank brands PPC works with',
  numberOfItems: brands.length,
  itemListElement: brands.map((brand, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Brand',
      name: brand.name,
      url: brand.url,
    },
  })),
};
---
<Base
  title="Catalog — Blank brands we print on — PPC"
  description="The blanks PPC prints on: WATC Studio and Velour Garments from Barcelona, and AS Colour. A tight, curated selection."
>
  <SEO
    slot="head"
    title="Catalog — Blank brands we print on — PPC"
    description="The blanks PPC prints on: WATC Studio and Velour Garments from Barcelona, and AS Colour. A tight, curated selection."
    ogImage="/og-catalog.jpg"
    canonicalUrl={canonicalUrl}
    schemas={[itemListSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: 'Catalog' }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        <p class="eyebrow mb-5">Blanks</p>
        <h1 class="text-display mb-6">Catalog</h1>
        <p class="lede text-mute">
          We've narrowed it to the blanks we trust — WATC Studio and Velour
          Garments from Barcelona, and AS Colour. The right base is half the
          result.
        </p>
      </div>

      <!-- Brand tiers -->
      <div class="space-y-16">
        {brandsByTier.map(({ tier, meta, brands: tierBrands }) => (
          <div class="md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20 pb-16 border-b border-[var(--color-rule)] last:border-0">
            <div class="mb-8 md:mb-0">
              <p class="text-h3">{meta.label}</p>
              {meta.desc && (
                <p class="font-baskerville text-mute text-sm mt-2 leading-relaxed">{meta.desc}</p>
              )}
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 border-l border-t border-[var(--color-rule)]">
              {tierBrands.map((brand) => (
                <BrandLogo brand={brand} />
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Footer note -->
      <div class="mt-14 md:grid md:grid-cols-[11rem_1fr] md:gap-12 lg:gap-20">
        <p class="section-num mb-4 md:mb-0">Notes</p>
        <div class="prose-ppc">
          <p class="text-mute">Or supply your own blank — same three-day turnaround.</p>
          <p>
            Need something specific?{' '}
            <a href="/#contact">Tell us — we'll source it.</a>
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href="/#contact" class="btn-solid">Send a brief →</a>
        <a href="/" class="btn-ghost">← Back to PPC</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
