---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { cases } from '../../data/cases';
import { caseImages } from '../../data/media';
import { SITE } from '../../data/site';
import CreateProduct from '../../components/CreateProduct.astro';

export function getStaticPaths() {
  return cases.map((c) => ({ params: { slug: c.slug }, props: { project: c } }));
}

const { project: c } = Astro.props;
const media = caseImages(c);
const canonicalUrl = `${SITE.url}/work/${c.slug}`;
const isVideo = (src: string) => /\.(mp4|webm|mov)$/i.test(src);

const SERVICE_PATH: Record<string, string> = {
  'Screen printing': '/screen-printing',
  Embroidery: '/embroidery',
  DTF: '/dtf',
};
const techniqueLinks = Object.keys(SERVICE_PATH).filter((name) => c.technique.includes(name));

const spec = [c.item, c.quantity].filter(Boolean).join(' · ');
const heroImg = c.garment ? new URL(c.garment, SITE.url).toString() : `${SITE.url}/og-default.jpg`;

const description = c.body
  ? c.body.length > 158
    ? `${c.body.slice(0, 155).trimEnd()}…`
    : c.body
  : `${c.client}: ${c.technique.toLowerCase()} on ${c.item.toLowerCase()} by PPC, a custom merch studio in Lisbon.`;

const creativeWorkSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `${canonicalUrl}#work`,
  name: `${c.client} — ${c.item}`,
  about: c.technique,
  url: canonicalUrl,
  image: heroImg,
  description: c.body || description,
  creator: { '@type': 'Organization', '@id': `${SITE.url}/#organization`, name: SITE.name },
  ...(c.clientUrl ? { mentions: { '@type': 'Organization', name: c.client, url: c.clientUrl } } : {}),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'PPC', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Work', item: `${SITE.url}/#work` },
    { '@type': 'ListItem', position: 3, name: c.client, item: canonicalUrl },
  ],
};
---
<Base
  title={`${c.client} — ${c.technique}, ${c.item} | PPC`}
  description={description}
>
  <SEO
    slot="head"
    title={`${c.client} — ${c.technique}, ${c.item} | PPC`}
    description={description}
    ogImage={c.garment ?? '/og-default.jpg'}
    canonicalUrl={canonicalUrl}
    ogType="article"
    schemas={[creativeWorkSchema, breadcrumbSchema]}
  />

  <Header />

  <main>
    <Breadcrumbs items={[{ name: 'PPC', href: '/' }, { name: c.client }]} />

    <div class="container-ppc pt-10 pb-24">
      <!-- Title block -->
      <div class="mb-14 pb-10 border-b border-[var(--color-rule)]">
        {c.date && <p class="eyebrow mb-5">{c.date}</p>}
        {!c.date && <p class="eyebrow mb-5">Project</p>}
        <h1 class="text-display mb-4">{c.client}</h1>
        <p class="lede text-mute">{c.technique} · {spec}</p>
        {c.clientUrl && (
          <p class="mt-4">
            <a href={c.clientUrl} target="_blank" rel="noopener noreferrer" class="plain-link">Visit {c.client} ↗</a>
          </p>
        )}
      </div>

      <div class="work-grid">
        <!-- Media -->
        <div class="work-media">
          {media.length ? (
            media.map((m) => (
              <figure>
                {isVideo(m.src) ? (
                  <video src={m.src} muted loop autoplay playsinline preload="metadata" controls></video>
                ) : (
                  <img src={m.src} alt={`${c.client} — ${m.label || c.item}`} loading="lazy" decoding="async" />
                )}
                {m.label && <figcaption class="section-num mt-2">{m.label}</figcaption>}
              </figure>
            ))
          ) : (
            <div class="aspect-[4/5] bg-[var(--color-surface)] border border-[var(--color-rule)] flex items-center justify-center">
              <span class="section-num">Image coming soon</span>
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="work-info">
          {c.body && <p class="prose-ppc mb-8">{c.body}</p>}

          {techniqueLinks.length > 0 && (
            <div class="mb-8 pt-6 border-t border-[var(--color-rule)]">
              <p class="label-text mb-3">Technique</p>
              <div class="flex flex-col gap-2">
                {techniqueLinks.map((name) => (
                  <a href={SERVICE_PATH[name]} class="plain-link">{name} →</a>
                ))}
              </div>
            </div>
          )}

          {(c.blank || (c.details && c.details.length > 0)) && (
            <div class="pt-6 border-t border-[var(--color-rule)]">
              <p class="label-text mb-3">Garment</p>
              {c.blank && <p class="prose-ppc mb-3">{c.blank}</p>}
              {c.details && c.details.length > 0 && (
                <ul class="work-details">
                  {c.details.map((d) => <li>{d}</li>)}
                </ul>
              )}
            </div>
          )}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-16 pt-10 border-t border-[var(--color-rule)] flex flex-col sm:flex-row sm:items-center gap-6">
        <a href="/#create" data-open-contact class="btn-cta">Create new product →</a>
        <a href="/" class="btn-ghost">← Back to the gallery</a>
      </div>
    </div>
  </main>

  <CreateProduct />
  <Footer />
</Base>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 820px) {
    .work-grid { grid-template-columns: 1.35fr 1fr; }
    .work-info { position: sticky; top: 2rem; }
  }
  .work-media { display: flex; flex-direction: column; gap: clamp(1.25rem, 3vw, 2.25rem); }
  .work-media figure { margin: 0; }
  .work-media img,
  .work-media video {
    width: 100%;
    height: auto;
    object-fit: contain;
    background: #fff;
    display: block;
  }
  .work-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem 1.5rem;
  }
  .work-details li {
    font-size: 0.8125rem;
    line-height: 1.35;
    color: var(--color-mute);
    padding-left: 0.9rem;
    position: relative;
  }
  .work-details li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-faint);
  }
  @media (max-width: 480px) {
    .work-details { grid-template-columns: 1fr; }
  }
</style>
