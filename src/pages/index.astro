---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
import Gallery from '../components/Gallery.astro';
import ProjectOverlay from '../components/ProjectOverlay.astro';
import InfoOverlay from '../components/InfoOverlay.astro';
import { SITE } from '../data/site';
import { cases } from '../data/cases';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['PPC', 'Printclub Collective'],
  legalName: SITE.legalName,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/favicon.svg`,
    width: 512,
    height: 512,
  },
  email: SITE.email,
  telephone: SITE.phonePlain,
  vatID: SITE.vatId,
  taxID: SITE.nipc,
  foundingDate: SITE.foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressRegion: SITE.address.city,
    addressCountry: SITE.address.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE.phonePlain,
    email: SITE.email,
    contactType: 'customer service',
    availableLanguage: ['English', 'Portuguese', 'Russian'],
  },
  sameAs: [SITE.instagramUrl],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Bank transfer, MBWay, Card',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
    },
  ],
  areaServed: [
    { '@type': 'City', name: 'Lisboa' },
    { '@type': 'City', name: 'Cascais' },
    { '@type': 'Country', name: 'Portugal' },
    { '@type': 'Place', name: 'European Union' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'PPC Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Screen printing', url: `${SITE.url}/screen-printing` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Embroidery', url: `${SITE.url}/embroidery` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'DTF printing', url: `${SITE.url}/dtf` } },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${SITE.url}/#process`,
  name: 'How to order custom printing in Lisbon',
  description: 'Three-step process to order custom screen printing, embroidery, or DTF from PPC.',
  totalTime: 'PT3D',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'EUR', value: '100' },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Send your logo or brief',
      text: `Send your logo or project brief via WhatsApp (${SITE.phone}), email (${SITE.email}), or Instagram DM (@ppcspace).`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Receive a quote within 24 hours',
      text: 'We respond within 24 hours with a technique recommendation, blank options, and a precise quote.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Approve and receive in 3 business days',
      text: 'You approve the proof. Production starts. Order is ready for pickup or delivery in 3 business days.',
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  '@id': `${SITE.url}/#work`,
  name: 'Selected work',
  itemListElement: cases.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'CreativeWork',
      name: `${c.client} — ${c.item}`,
      about: c.technique,
      url: `${SITE.url}/#project/${c.slug}`,
    },
  })),
};
---
<Base
  title="PPC — Custom print studio in Lisbon. 3-day turnaround."
  description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
>
  <SEO
    slot="head"
    title="PPC — Custom print studio in Lisbon. 3-day turnaround."
    description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
    ogImage="/og-default.jpg"
    canonicalUrl={SITE.url}
    schemas={[organizationSchema, localBusinessSchema, websiteSchema, howToSchema, itemListSchema]}
  />

  <InfoOverlay />

  <div class="home">
    <header class="home__hero">
      <h1 class="home__h1">Merch worth keeping.</h1>
      <p class="home__sub">Custom print studio in Lisbon. From 1 piece. Ready in 3 days.</p>
    </header>
    <Gallery />
  </div>

  <ProjectOverlay />

  <!-- Lock the document on the gallery page so iOS can't rubber-band /
       pull-to-refresh and fight the gallery's own scroll. Homepage only. -->
  <style is:global>
    html, body {
      height: 100%;
      overflow: hidden;
      overscroll-behavior: none;
    }
    body {
      position: fixed;
      inset: 0;
      width: 100%;
    }
  </style>

  <style>
    /* Hero headline sits above the gallery; the gallery fills the rest. */
    .home {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
    }
    .home__hero {
      flex: 0 0 auto;
      text-align: center;
      /* top padding clears the fixed logo/Menu row */
      padding: clamp(4.25rem, 9vw, 7rem) 1.25rem clamp(0.75rem, 1.6vh, 1.4rem);
    }
    .home__h1 {
      margin: 0;
      font-family: var(--font-sans);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.02;
      font-size: clamp(1.75rem, 6vw, 3.25rem);
      color: var(--color-text);
    }
    .home__sub {
      margin: 0.5rem 0 0;
      color: var(--color-mute);
      font-size: clamp(0.875rem, 2.2vw, 1.0625rem);
      letter-spacing: 0;
    }
  </style>
</Base>
