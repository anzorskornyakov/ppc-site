---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
import { clients } from '../data/clients';
import { services } from '../data/services';

const workImages = [
  { src: '/photos/work-01.jpg', alt: 'Screen-printed t-shirts — custom order' },
  { src: '/photos/work-02.jpg', alt: 'Embroidered hoodie — custom logo' },
  { src: '/photos/work-03.jpg', alt: 'DTF print on tote bag' },
  { src: '/photos/work-04.jpg', alt: 'Screen-printed uniform — hospitality client' },
  { src: '/photos/work-05.jpg', alt: 'Embroidered cap — branded merchandise' },
  { src: '/photos/work-06.jpg', alt: 'Screen-printed crew sweatshirts' },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['PPC', 'Printclub Collective'],
  legalName: SITE.legalName,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/favicon.svg`,
    width: 512,
    height: 512,
  },
  email: SITE.email,
  telephone: SITE.phonePlain,
  vatID: SITE.vatId,
  taxID: SITE.nipc,
  foundingDate: SITE.foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressRegion: SITE.address.city,
    addressCountry: SITE.address.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE.phonePlain,
    email: SITE.email,
    contactType: 'customer service',
    availableLanguage: ['English', 'Portuguese', 'Russian'],
  },
  sameAs: [SITE.instagramUrl],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Bank transfer, MBWay, Card',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
    },
  ],
  areaServed: [
    { '@type': 'City', name: 'Lisboa' },
    { '@type': 'City', name: 'Cascais' },
    { '@type': 'Country', name: 'Portugal' },
    { '@type': 'Place', name: 'European Union' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'PPC Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Screen printing', url: `${SITE.url}/screen-printing` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Embroidery', url: `${SITE.url}/embroidery` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'DTF printing', url: `${SITE.url}/dtf` } },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${SITE.url}/#process`,
  name: 'How to order custom printing in Lisbon',
  description: 'Three-step process to order custom screen printing, embroidery, or DTF from PPC.',
  totalTime: 'PT3D',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'EUR', value: '100' },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Send your logo or brief',
      text: `Send your logo or project brief via WhatsApp (${SITE.phone}), email (${SITE.email}), or Instagram DM (@ppcspace).`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Receive a quote within 24 hours',
      text: 'We respond within 24 hours with a technique recommendation, blank options, and a precise quote.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Approve and receive in 3 business days',
      text: 'You approve the proof. Production starts. Order is ready for pickup or delivery in 3 business days.',
    },
  ],
};
---
<Base
  title="PPC — Custom print studio in Lisbon. 3-day turnaround."
  description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
>
  <SEO
    slot="head"
    title="PPC — Custom print studio in Lisbon. 3-day turnaround."
    description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
    ogImage="/og-default.jpg"
    canonicalUrl={SITE.url}
    schemas={[organizationSchema, localBusinessSchema, websiteSchema, howToSchema]}
  />

  <Header />

  <main>
    <!-- 00: Hero -->
    <section id="cover" class="container-ppc pt-14 md:pt-24 pb-10 md:pb-16">
      <p class="eyebrow mb-7">Open for briefs · Lisbon</p>

      <h1 class="text-display max-w-[18ch]">
        Custom print studio in <span class="text-accent">Lisbon</span>.
      </h1>

      <div class="mt-8 md:mt-12 flex flex-col md:flex-row md:items-end md:justify-between gap-8">
        <p class="lede">
          Screen printing, embroidery and DTF. From a single piece,
          ready in three business days.
        </p>
        <div class="flex flex-wrap items-center gap-3 shrink-0">
          <a href="#contact" class="btn-solid">Send a brief</a>
          <a href="/catalog" class="btn-outline">View the catalog</a>
        </div>
      </div>

      <!-- Hero image -->
      <figure class="mt-12 md:mt-16">
        <div class="w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-2xl bg-[var(--color-surface)]">
          <img src="/photos/studio-hero.jpg" alt="PPC studio in Campolide, Lisbon" class="w-full h-full object-cover" />
        </div>
      </figure>
    </section>

    <!-- 01: What we do — service index -->
    <Section id="services" num="01.000" label="What we do">
      <ul class="list-none -mt-2">
        {services.map((s) => (
          <li>
            <a href={s.path} class="group index-row no-underline">
              <span class="flex items-baseline gap-4">
                <span class="section-num hidden sm:inline">{s.sectionNum}</span>
                <span class="text-h2 group-hover:text-[var(--color-accent)] transition-colors">{s.name}</span>
              </span>
              <span class="flex items-baseline gap-5 shrink-0 text-mute">
                <span class="font-body text-sm hidden sm:inline">from €{s.priceLow}/pc · min {s.minOrder}</span>
                <span class="font-body text-xl group-hover:text-[var(--color-accent)] group-hover:translate-x-1 transition-all">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="font-body text-mute mt-6 text-sm">Every order ready in {SITE.turnaround}.</p>
    </Section>

    <!-- 02: Blanks -->
    <Section id="blanks" num="02.000" label="Blanks">
      <p class="prose-ppc mb-8">
        We print on every brand available through Toptex — Europe's largest
        blank supplier — plus our own premium selection from WATC Studio and
        Velour Garments in Barcelona. <span class="text-mute">Or supply your own.
        Same three-day turnaround.</span>
      </p>
      <a href="/catalog" class="btn-ghost">View the catalog →</a>
    </Section>

    <!-- 03: Studio -->
    <Section id="studio-section" num="03.000" label="Studio">
      <div class="mb-8">
        <p class="prose-ppc">{SITE.address.street}</p>
        <p class="prose-ppc">{SITE.address.postal} {SITE.address.city} · {SITE.address.district}</p>
        <p class="prose-ppc text-mute mt-1">Open by appointment.</p>
      </div>
      <a href="/studio" class="btn-ghost">Visit the studio →</a>
      <figure class="mt-10">
        <div class="w-full aspect-[16/8] overflow-hidden rounded-2xl bg-[var(--color-surface)]">
          <img
            src="/photos/studio-detail-01.jpg"
            alt="PPC studio interior — Calçada dos Mestres 34, Lisbon"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <figcaption class="section-num mt-3">Studio · Calçada dos Mestres 34, Campolide</figcaption>
      </figure>
    </Section>

    <!-- 04: Work -->
    <Section id="work" num="04.000" label="Selected work">
      <p class="prose-ppc mb-10">
        The newest and most talked-about venues in Lisbon — all came
        through word of mouth, before we had a brand or a space.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-10">
        {workImages.map((img) => (
          <figure class="aspect-square overflow-hidden rounded-xl bg-[var(--color-surface)] group">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.05]"
            />
          </figure>
        ))}
      </div>
      <div class="flex flex-wrap gap-x-2 gap-y-1 items-center">
        {clients.map((c, i) => (
          <>
            {i > 0 && <span class="text-faint">·</span>}
            <span class="font-body text-mute text-sm">{c}</span>
          </>
        ))}
      </div>
    </Section>

    <!-- 05: Contact -->
    <!-- 05: Blue CTA band -->
    <section class="bg-accent text-white mt-8 md:mt-16">
      <div class="container-ppc py-20 md:py-28">
        <p class="font-body text-sm font-medium uppercase tracking-[0.14em] text-white/70 mb-6">Let's work together</p>
        <h2 class="text-h1 text-white max-w-[16ch]">Have a project in mind?</h2>
        <p class="font-body text-lg text-white/80 max-w-xl mt-6">
          Send your logo or brief. We reply within 24 hours with a technique
          recommendation, blank options and a precise quote.
        </p>
        <div class="flex flex-wrap items-center gap-3 mt-10">
          <a href="#contact" class="font-body text-sm font-medium px-6 py-3 rounded-full bg-white text-[var(--color-accent)] hover:bg-white/90 transition-colors">Send a brief</a>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="font-body text-sm font-medium px-6 py-3 rounded-full border border-white/40 text-white hover:bg-white/10 transition-colors">WhatsApp ↗</a>
        </div>
      </div>
    </section>

    <!-- 06: Contact -->
    <Section id="contact" num="05.000" label="Send a brief">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <p class="prose-ppc mb-8">
            Tell us what you need. We'll get back to you within 24 hours.
          </p>
          <ul class="list-none font-body text-[0.9375rem] space-y-3">
            <li class="flex gap-6">
              <span class="text-mute w-24 shrink-0">WhatsApp</span>
              <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a>
            </li>
            <li class="flex gap-6">
              <span class="text-mute w-24 shrink-0">Email</span>
              <a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>
            </li>
            <li class="flex gap-6">
              <span class="text-mute w-24 shrink-0">Instagram</span>
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a>
            </li>
          </ul>
        </div>
        <div>
          <ContactForm />
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Base>
