---
import Base from '../layouts/Base.astro';
import SEO from '../components/SEO.astro';
import { SITE } from '../data/site';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['PPC', 'Printclub Collective'],
  legalName: SITE.legalName,
  url: SITE.url,
  logo: { '@type': 'ImageObject', url: `${SITE.url}/favicon.png`, width: 512, height: 512 },
  email: SITE.email,
  telephone: SITE.phonePlain,
  vatID: SITE.vatId,
  taxID: SITE.nipc,
  foundingDate: SITE.foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE.phonePlain,
    email: SITE.email,
    contactType: 'customer service',
    availableLanguage: ['English', 'Portuguese', 'Russian'],
  },
  sameAs: [SITE.instagramUrl],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: { '@type': 'GeoCoordinates', latitude: SITE.geo.lat, longitude: SITE.geo.lon },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Bank transfer, MBWay, Card',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '10:00', closes: '19:00' },
  ],
  areaServed: [
    { '@type': 'City', name: 'Lisboa' },
    { '@type': 'City', name: 'Cascais' },
    { '@type': 'Country', name: 'Portugal' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'PPC Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Screen printing', url: `${SITE.url}/screen-printing` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Embroidery', url: `${SITE.url}/embroidery` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'DTF printing', url: `${SITE.url}/dtf` } },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};
---
<Base
  title="PPC — Custom print studio in Lisbon. 3-day turnaround."
  description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
>
  <SEO
    slot="head"
    title="PPC — Custom print studio in Lisbon. 3-day turnaround."
    description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
    ogImage="/og-default.jpg"
    canonicalUrl={SITE.url}
    schemas={[organizationSchema, localBusinessSchema, websiteSchema]}
  />

  <main class="cover">
    <div class="cover__inner">
      <img class="cover__logo" src="/logo.webp" alt={SITE.name} width="200" height="92" />

      <h1 class="cover__lead">
        Custom print studio in Lisbon. Screen printing, embroidery and DTF —
        from one piece, ready in three days.
      </h1>

      <nav class="cover__nav" aria-label="Primary">
        <a href="/archive">Archive</a>
        <a href="/catalog">Catalog</a>
        <a href="/contact">Start a project</a>
      </nav>

      <nav class="cover__sub" aria-label="Services">
        <a href="/screen-printing">Screen printing</a>
        <a href="/embroidery">Embroidery</a>
        <a href="/dtf">DTF</a>
        <a href="/studio">Studio</a>
      </nav>

      <ul class="cover__contact">
        <li><span>WhatsApp</span><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">{SITE.phone}</a></li>
        <li><span>Telegram</span><a href={SITE.telegramUrl} target="_blank" rel="noopener noreferrer">{SITE.telegram}</a></li>
        <li><span>Email</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><span>Instagram</span><a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer">{SITE.instagram}</a></li>
      </ul>

      <p class="cover__addr">{SITE.address.full} · {SITE.address.district}</p>
    </div>
  </main>

  <style>
    .cover {
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: clamp(3rem, 8vh, 6rem) clamp(1.5rem, 6vw, 5rem);
    }
    .cover__inner {
      width: 100%;
      max-width: 46rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: clamp(1.75rem, 4vh, 2.75rem);
    }
    .cover__logo { height: clamp(2.75rem, 6vw, 4rem); width: auto; }

    .cover__lead {
      margin: 0;
      font-weight: 700;
      letter-spacing: -0.015em;
      line-height: 1.12;
      font-size: clamp(1.5rem, 3.6vw, 2.5rem);
      max-width: 26ch;
      color: var(--color-text);
    }

    .cover__nav {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .cover__nav a {
      font-weight: 700;
      letter-spacing: -0.01em;
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      line-height: 1.15;
      color: var(--color-text);
      text-decoration: none;
      width: fit-content;
    }
    .cover__nav a:hover { color: var(--color-accent); }

    .cover__sub {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1rem;
    }
    .cover__sub a {
      font-size: 0.875rem;
      color: var(--color-mute);
      text-decoration: none;
    }
    .cover__sub a:hover { color: var(--color-text); }

    .cover__contact {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.875rem;
      display: grid;
      gap: 0.3rem;
    }
    .cover__contact span { display: inline-block; width: 6rem; color: var(--color-mute); }

    .cover__addr {
      margin: 0;
      font-size: 0.8125rem;
      color: var(--color-faint);
    }
  </style>
</Base>
