---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
import { clients } from '../data/clients';
import { services } from '../data/services';

const workImages = [
  { src: '/photos/work-01.jpg', alt: 'Screen-printed t-shirts — custom order' },
  { src: '/photos/work-02.jpg', alt: 'Embroidered hoodie — custom logo' },
  { src: '/photos/work-03.jpg', alt: 'DTF print on tote bag' },
  { src: '/photos/work-04.jpg', alt: 'Screen-printed uniform — hospitality client' },
  { src: '/photos/work-05.jpg', alt: 'Embroidered cap — branded merchandise' },
  { src: '/photos/work-06.jpg', alt: 'Screen-printed crew sweatshirts' },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['PPC', 'Printclub Collective'],
  legalName: SITE.legalName,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/favicon.svg`,
    width: 512,
    height: 512,
  },
  email: SITE.email,
  telephone: SITE.phonePlain,
  vatID: SITE.vatId,
  taxID: SITE.nipc,
  foundingDate: SITE.foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressRegion: SITE.address.city,
    addressCountry: SITE.address.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE.phonePlain,
    email: SITE.email,
    contactType: 'customer service',
    availableLanguage: ['English', 'Portuguese', 'Russian'],
  },
  sameAs: [SITE.instagramUrl],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Bank transfer, MBWay, Card',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
    },
  ],
  areaServed: [
    { '@type': 'City', name: 'Lisboa' },
    { '@type': 'City', name: 'Cascais' },
    { '@type': 'Country', name: 'Portugal' },
    { '@type': 'Place', name: 'European Union' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'PPC Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Screen printing', url: `${SITE.url}/screen-printing` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Embroidery', url: `${SITE.url}/embroidery` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'DTF printing', url: `${SITE.url}/dtf` } },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${SITE.url}/#process`,
  name: 'How to order custom printing in Lisbon',
  description: 'Three-step process to order custom screen printing, embroidery, or DTF from PPC.',
  totalTime: 'PT3D',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'EUR', value: '100' },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Send your logo or brief',
      text: `Send your logo or project brief via WhatsApp (${SITE.phone}), email (${SITE.email}), or Instagram DM (@ppcspace).`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Receive a quote within 24 hours',
      text: 'We respond within 24 hours with a technique recommendation, blank options, and a precise quote.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Approve and receive in 3 business days',
      text: 'You approve the proof. Production starts. Order is ready for pickup or delivery in 3 business days.',
    },
  ],
};
---
<Base
  title="PPC — Custom print studio in Lisbon. 3-day turnaround."
  description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
>
  <SEO
    slot="head"
    title="PPC — Custom print studio in Lisbon. 3-day turnaround."
    description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
    ogImage="/og-default.jpg"
    canonicalUrl={SITE.url}
    schemas={[organizationSchema, localBusinessSchema, websiteSchema, howToSchema]}
  />

  <Header />

  <main>
    <!-- 00: Cover / title block -->
    <section id="cover" class="container-ppc pt-10 md:pt-14 pb-16 md:pb-24">
      <!-- title-block metadata row -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-1 section-num pb-5 mb-10 md:mb-14 border-b border-[var(--color-rule)]">
        <span>00.000 — Index</span>
        <span class="text-faint hidden sm:inline">/</span>
        <span>Lisbon, Portugal</span>
        <span class="text-faint hidden sm:inline">/</span>
        <span>Est. {SITE.foundingDate}</span>
        <span class="ml-auto text-accent">● Open for briefs</span>
      </div>

      <h1 class="font-barlow font-bold uppercase leading-[0.86] tracking-[-0.02em]"
          style="font-size: clamp(4rem, 17vw, 13rem);">
        Portugal<br />Print Club
      </h1>

      <div class="mt-10 md:mt-14 grid md:grid-cols-[1fr_auto] md:items-end gap-8">
        <p class="lede text-mute">
          A custom print studio in Lisbon — screen printing,
          embroidery and DTF. From a single piece, ready in three business days.
        </p>
        <a href="#contact" class="btn-solid justify-self-start md:justify-self-end">Send a brief →</a>
      </div>
    </section>

    <!-- 01: What we do — service index -->
    <Section id="services" num="01.000" label="What we do">
      <ul class="list-none">
        {services.map((s) => (
          <li>
            <a href={s.path} class="group index-row no-underline">
              <span class="font-barlow font-semibold uppercase tracking-[0.01em] leading-none group-hover:text-[var(--color-accent)] transition-colors"
                    style="font-size: clamp(1.75rem, 4vw, 2.75rem);">
                {s.name}
              </span>
              <span class="flex items-baseline gap-4 shrink-0 text-mute">
                <span class="font-barlow text-sm uppercase tracking-[0.06em] hidden sm:inline">
                  from €{s.priceLow}/pc · min {s.minOrder}
                </span>
                <span class="font-barlow text-xl group-hover:text-[var(--color-accent)] group-hover:translate-x-1 transition-all">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="font-baskerville text-mute mt-6" style="font-size:0.9375rem;">
        Every order ready in {SITE.turnaround}.
      </p>
    </Section>

    <!-- 02: Blanks -->
    <Section id="blanks" num="02.000" label="Blanks">
      <p class="prose-ppc mb-8">
        We print on every brand available through Toptex — Europe's largest
        blank supplier — plus our own premium selection from WATC Studio and
        Velour Garments in Barcelona. <span class="text-mute">Or supply your own.
        Same three-day turnaround.</span>
      </p>
      <a href="/catalog" class="btn-ghost">View the catalog →</a>
    </Section>

    <!-- 03: Studio -->
    <Section id="studio-section" num="03.000" label="Studio">
      <div class="mb-8">
        <p class="prose-ppc">{SITE.address.street}</p>
        <p class="prose-ppc">{SITE.address.postal} {SITE.address.city} · {SITE.address.district}</p>
        <p class="prose-ppc text-mute mt-1">Open by appointment.</p>
      </div>
      <a href="/studio" class="btn-ghost mb-12">Visit the studio →</a>
      <figure class="mt-10">
        <div class="w-full aspect-[16/8] overflow-hidden bg-[rgba(20,17,14,0.06)]">
          <img
            src="/photos/studio-hero.jpg"
            alt="PPC studio interior — Calçada dos Mestres 34, Lisbon"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <figcaption class="section-num mt-3">Fig. 01 — Studio, Calçada dos Mestres 34</figcaption>
      </figure>
    </Section>

    <!-- 04: Work -->
    <Section id="work" num="04.000" label="Selected work">
      <p class="prose-ppc mb-10">
        The newest and most talked-about venues in Lisbon — all came
        through word of mouth, before we had a brand or a space.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-1.5 md:gap-2 mb-8">
        {workImages.map((img, i) => (
          <figure class="aspect-square overflow-hidden bg-[rgba(20,17,14,0.06)] relative group">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
            />
            <figcaption class="absolute bottom-2 left-2 section-num text-[var(--color-bg)] mix-blend-difference">
              {String(i + 1).padStart(2, '0')}
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="font-barlow text-mute text-sm tracking-[0.04em] leading-relaxed">
        {clients.join('   ·   ')}
      </p>
    </Section>

    <!-- 05: Contact -->
    <Section id="contact" num="05.000" label="Send a brief">
      <p class="prose-ppc mb-10">
        Send your logo or project brief. We respond within 24 hours with a
        technique recommendation, blank options and a precise quote.
      </p>
      <div class="max-w-md">
        <ContactForm />
      </div>
    </Section>

    <!-- 06: Colophon -->
    <Section id="colophon" num="06.000" label="Colophon">
      <div class="grid sm:grid-cols-2 gap-x-12 gap-y-10">
        <div>
          <p class="label-text mb-3">Contact</p>
          <ul class="list-none font-barlow text-[0.9375rem] space-y-2">
            <li class="flex gap-6">
              <span class="text-mute w-20 shrink-0">WhatsApp</span>
              <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a>
            </li>
            <li class="flex gap-6">
              <span class="text-mute w-20 shrink-0">Email</span>
              <a href={`mailto:${SITE.email}`} class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>
            </li>
            <li class="flex gap-6">
              <span class="text-mute w-20 shrink-0">Instagram</span>
              <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a>
            </li>
          </ul>
        </div>
        <div>
          <p class="label-text mb-3">Legal</p>
          <ul class="list-none font-barlow text-[0.9375rem] space-y-2 text-mute">
            <li>{SITE.legalName}</li>
            <li>NIPC {SITE.nipc}</li>
            <li>{SITE.address.city}, {SITE.address.country} · Est. {SITE.foundingDate}</li>
            <li>Prices exclude 23% VAT.</li>
          </ul>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Base>
