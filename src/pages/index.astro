---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
import { clients } from '../data/clients';

const workImages = [
  { src: '/photos/work-01.jpg', alt: 'Screen-printed t-shirts — custom order' },
  { src: '/photos/work-02.jpg', alt: 'Embroidered hoodie — custom logo' },
  { src: '/photos/work-03.jpg', alt: 'DTF print on tote bag' },
  { src: '/photos/work-04.jpg', alt: 'Screen-printed uniform — hospitality client' },
  { src: '/photos/work-05.jpg', alt: 'Embroidered cap — branded merchandise' },
  { src: '/photos/work-06.jpg', alt: 'Screen-printed crew sweatshirts' },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  alternateName: ['PPC', 'Printclub Collective'],
  legalName: SITE.legalName,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/favicon.svg`,
    width: 512,
    height: 512,
  },
  email: SITE.email,
  telephone: SITE.phonePlain,
  vatID: SITE.vatId,
  taxID: SITE.nipc,
  foundingDate: SITE.foundingDate,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressRegion: SITE.address.city,
    addressCountry: SITE.address.countryCode,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE.phonePlain,
    email: SITE.email,
    contactType: 'customer service',
    availableLanguage: ['English', 'Portuguese', 'Russian'],
  },
  sameAs: [SITE.instagramUrl],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${SITE.url}/#studio`,
  name: SITE.name,
  image: [
    `${SITE.url}/photos/studio-hero.jpg`,
    `${SITE.url}/photos/studio-detail-01.jpg`,
  ],
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    postalCode: SITE.address.postal,
    addressCountry: SITE.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lon,
  },
  url: SITE.url,
  telephone: SITE.phonePlain,
  email: SITE.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: 'Bank transfer, MBWay, Card',
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday', 'Sunday'],
      opens: '00:00',
      closes: '00:00',
    },
  ],
  areaServed: [
    { '@type': 'City', name: 'Lisboa' },
    { '@type': 'City', name: 'Cascais' },
    { '@type': 'Country', name: 'Portugal' },
    { '@type': 'Place', name: 'European Union' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'PPC Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Screen printing', url: `${SITE.url}/screen-printing` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Embroidery', url: `${SITE.url}/embroidery` } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'DTF printing', url: `${SITE.url}/dtf` } },
    ],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  publisher: { '@id': `${SITE.url}/#organization` },
  inLanguage: 'en',
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${SITE.url}/#process`,
  name: 'How to order custom printing in Lisbon',
  description: 'Three-step process to order custom screen printing, embroidery, or DTF from PPC.',
  totalTime: 'PT3D',
  estimatedCost: { '@type': 'MonetaryAmount', currency: 'EUR', value: '100' },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Send your logo or brief',
      text: `Send your logo or project brief via WhatsApp (${SITE.phone}), email (${SITE.email}), or Instagram DM (@ppcspace).`,
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Receive a quote within 24 hours',
      text: 'We respond within 24 hours with a technique recommendation, blank options, and a precise quote.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Approve and receive in 3 business days',
      text: 'You approve the proof. Production starts. Order is ready for pickup or delivery in 3 business days.',
    },
  ],
};
---
<Base
  title="PPC — Custom print studio in Lisbon. 3-day turnaround."
  description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
>
  <SEO
    slot="head"
    title="PPC — Custom print studio in Lisbon. 3-day turnaround."
    description="Portugal Print Club. Screen printing, embroidery, DTF printing in Lisbon. From 1 piece. Ready in 3 business days. Studio open for visits in Campolide."
    ogImage="/og-default.jpg"
    canonicalUrl={SITE.url}
    schemas={[organizationSchema, localBusinessSchema, websiteSchema, howToSchema]}
  />

  <Header />

  <main>
    <!-- 00: Cover -->
    <section id="cover" class="divider py-20 md:py-28">
      <div class="container-ppc">
        <p class="section-num mb-10 md:mb-14">00.000</p>
        <div>
          <h1 class="font-barlow font-semibold leading-none tracking-tight"
              style="font-size: clamp(4.5rem, 13vw, 9rem);">PPC</h1>
          <p class="font-barlow font-semibold text-mute leading-tight tracking-tight"
             style="font-size: clamp(1.75rem, 5vw, 3.5rem); margin-top: 0.2em;">
            PORTUGAL PRINT CLUB
          </p>
          <p class="font-barlow text-mute"
             style="font-size: clamp(0.9rem, 1.5vw, 1.1rem); margin-top: 1em; letter-spacing: 0.04em;">
            LISBON · 2026
          </p>
        </div>
      </div>
    </section>

    <!-- 01: What we do -->
    <Section id="services" num="01.000" label="WHAT WE DO">
      <p class="font-baskerville mb-10 max-w-sm leading-relaxed" style="font-size:1rem;">
        A custom print studio in Lisbon.
      </p>
      <ul class="space-y-2 list-none mb-10">
        <li>
          <a href="/screen-printing"
             class="font-barlow font-semibold uppercase tracking-[0.02em] hover:text-[var(--color-accent)] transition-colors"
             style="font-size: clamp(1.5rem, 3vw, 2rem);">
            → Screen printing
          </a>
        </li>
        <li>
          <a href="/embroidery"
             class="font-barlow font-semibold uppercase tracking-[0.02em] hover:text-[var(--color-accent)] transition-colors"
             style="font-size: clamp(1.5rem, 3vw, 2rem);">
            → Embroidery
          </a>
        </li>
        <li>
          <a href="/dtf"
             class="font-barlow font-semibold uppercase tracking-[0.02em] hover:text-[var(--color-accent)] transition-colors"
             style="font-size: clamp(1.5rem, 3vw, 2rem);">
            → DTF
          </a>
        </li>
      </ul>
      <p class="font-baskerville text-mute" style="font-size:0.9rem;">Ready in 3 business days.</p>
    </Section>

    <!-- 02: Blanks -->
    <Section id="blanks" num="02.000" label="BLANKS">
      <p class="font-baskerville mb-5 max-w-md leading-relaxed" style="font-size:1rem;">
        We work with every brand available through Toptex — Europe's largest blank
        supplier — plus our own premium selection from WATC Studio and Velour Garments
        in Barcelona.
      </p>
      <p class="font-baskerville text-mute mb-10 max-w-md" style="font-size:1rem;">
        Or supply your own. Same 3-day turnaround.
      </p>
      <a href="/catalog"
         class="font-barlow font-medium uppercase tracking-[0.04em] text-sm hover:text-[var(--color-accent)] transition-colors">
        → /catalog
      </a>
    </Section>

    <!-- 03: Studio -->
    <Section id="studio-section" num="03.000" label="STUDIO">
      <div class="mb-8">
        <p class="font-baskerville" style="font-size:1rem;">{SITE.address.street}</p>
        <p class="font-baskerville" style="font-size:1rem;">{SITE.address.postal} {SITE.address.city} · {SITE.address.district}</p>
        <p class="font-baskerville text-mute mt-1" style="font-size:1rem;">By appointment.</p>
      </div>
      <a href="/studio"
         class="font-barlow font-medium uppercase tracking-[0.04em] text-sm hover:text-[var(--color-accent)] transition-colors">
        → /studio
      </a>
      <div class="mt-12 w-full aspect-[16/7] overflow-hidden bg-[rgba(10,10,10,0.06)]">
        <img
          src="/photos/studio-hero.jpg"
          alt="PPC studio interior — Calçada dos Mestres 34, Lisbon"
          loading="lazy"
          class="w-full h-full object-cover"
        />
      </div>
      <p class="section-num mt-3">Studio · Calçada dos Mestres 34</p>
    </Section>

    <!-- 04: Work -->
    <Section id="work" num="04.000" label="WORK">
      <p class="font-baskerville max-w-sm mb-10 leading-relaxed" style="font-size:1rem;">
        The newest and most talked-about venues in Lisbon.
        All came through word of mouth, before we had a brand or a space.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 mb-8">
        {workImages.map((img) => (
          <div class="aspect-square overflow-hidden bg-[rgba(10,10,10,0.06)]">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>
      <p class="font-barlow text-mute text-sm leading-relaxed tracking-wide">
        {clients.join('  ·  ')}
      </p>
    </Section>

    <!-- 05: Contact -->
    <Section id="contact" num="05.000" label="SEND A BRIEF">
      <div class="max-w-md">
        <ContactForm />
      </div>
    </Section>

    <!-- 06: Colophon -->
    <Section id="colophon" num="06.000" label="COLOPHON">
      <div class="space-y-8 font-barlow" style="font-size:0.875rem;">
        <div class="space-y-1">
          <p>{SITE.legalName} · NIPC {SITE.nipc}</p>
          <p class="text-mute">{SITE.address.city}, {SITE.address.country} · {SITE.foundingDate}</p>
        </div>
        <div class="space-y-3">
          <p class="flex gap-8">
            <span class="text-mute w-24 shrink-0">WhatsApp</span>
            <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer"
               class="hover:text-[var(--color-accent)] transition-colors">{SITE.phone}</a>
          </p>
          <p class="flex gap-8">
            <span class="text-mute w-24 shrink-0">Email</span>
            <a href={`mailto:${SITE.email}`}
               class="hover:text-[var(--color-accent)] transition-colors">{SITE.email}</a>
          </p>
          <p class="flex gap-8">
            <span class="text-mute w-24 shrink-0">Instagram</span>
            <a href={SITE.instagramUrl} target="_blank" rel="noopener noreferrer"
               class="hover:text-[var(--color-accent)] transition-colors">{SITE.instagram}</a>
          </p>
        </div>
        <p class="text-mute">Prices exclude 23% VAT.</p>
      </div>
    </Section>
  </main>

  <Footer />
</Base>
